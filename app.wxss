/** 全局视觉基础：统一为“云枢蓝”品牌色，同时保持管理端的卡片化工业风。 */
page {
  --hive-primary: #1f6fff;
  --hive-primary-dark: #0b2a6f;
  --hive-ink: #071f5f;
  --hive-muted: #64748b;
  --hive-line: #dbe8ff;
  --hive-card: rgba(255, 255, 255, 0.94);
  --hive-soft: #eef6ff;
  --hive-bg: #f4f8ff;
  min-height: 100vh;
  background:
    radial-gradient(circle at 14% 0%, rgba(103, 183, 255, .26), transparent 36%),
    linear-gradient(180deg, #f7fbff 0%, #ffffff 100%);
  color: var(--hive-ink);
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
  box-sizing: border-box;
}

.container {
  box-sizing: border-box;
}

.hive-card {
  background: var(--hive-card);
  border: 1rpx solid rgba(226, 232, 240, .9);
  border-radius: 32rpx;
  box-shadow: 0 16rpx 40rpx rgba(15, 23, 42, .06);
}

.hive-title {
  color: var(--hive-ink);
  font-size: 34rpx;
  font-weight: 800;
  letter-spacing: .5rpx;
}

.hive-subtitle {
  color: var(--hive-muted);
  font-size: 24rpx;
  line-height: 1.6;
}

.hive-section-title {
  position: relative;
  padding-left: 14rpx;
  color: var(--hive-ink);
  font-size: 30rpx;
  font-weight: 800;
}

.hive-section-title::before {
  content: "";
  position: absolute;
  left: 0;
  top: 50%;
  width: 6rpx;
  height: 28rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #67b7ff, #1f6fff);
  transform: translateY(-50%);
}

.hive-primary-btn {
  background: linear-gradient(135deg, #67b7ff 0%, #1f6fff 62%, #0b2a6f 100%);
  color: #fff;
  box-shadow: 0 10rpx 24rpx rgba(31, 111, 255, .24);
}

.hive-ghost-btn {
  background: #eef6ff;
  color: var(--hive-primary-dark);
}

.hive-status {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  padding: 8rpx 18rpx;
  font-size: 22rpx;
  font-weight: 800;
}

.hive-empty {
  padding: 96rpx 24rpx;
  text-align: center;
  color: #94a3b8;
  font-size: 26rpx;
}
