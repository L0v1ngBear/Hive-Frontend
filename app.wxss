/** 全局视觉基础：保持小程序当前橙金主色，同时向管理端的卡片化工业风靠齐。 */
page {
  --hive-primary: #fbab06;
  --hive-primary-dark: #d48806;
  --hive-ink: #0f172a;
  --hive-muted: #64748b;
  --hive-line: #e5e7eb;
  --hive-card: rgba(255, 255, 255, 0.94);
  --hive-soft: #fff8ec;
  --hive-bg: #f6f8fc;
  min-height: 100vh;
  background:
    radial-gradient(circle at 12% 0%, rgba(251, 171, 6, .18), transparent 34%),
    linear-gradient(180deg, #f8fafc 0%, #ffffff 100%);
  color: var(--hive-ink);
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
  box-sizing: border-box;
}

.container {
  box-sizing: border-box;
}

.hive-card {
  background: var(--hive-card);
  border: 1rpx solid rgba(226, 232, 240, .9);
  border-radius: 32rpx;
  box-shadow: 0 16rpx 40rpx rgba(15, 23, 42, .06);
}

.hive-title {
  color: var(--hive-ink);
  font-size: 34rpx;
  font-weight: 800;
  letter-spacing: .5rpx;
}

.hive-subtitle {
  color: var(--hive-muted);
  font-size: 24rpx;
  line-height: 1.6;
}

.hive-section-title {
  position: relative;
  padding-left: 14rpx;
  color: var(--hive-ink);
  font-size: 30rpx;
  font-weight: 800;
}

.hive-section-title::before {
  content: "";
  position: absolute;
  left: 0;
  top: 50%;
  width: 6rpx;
  height: 28rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #ffbe45, #fbab06);
  transform: translateY(-50%);
}

.hive-primary-btn {
  background: linear-gradient(135deg, #ffb84d 0%, #f59e0b 100%);
  color: #fff;
  box-shadow: 0 10rpx 24rpx rgba(251, 171, 6, .24);
}

.hive-ghost-btn {
  background: #fff7e8;
  color: var(--hive-primary-dark);
}

.hive-status {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  padding: 8rpx 18rpx;
  font-size: 22rpx;
  font-weight: 800;
}

.hive-empty {
  padding: 96rpx 24rpx;
  text-align: center;
  color: #94a3b8;
  font-size: 26rpx;
}
