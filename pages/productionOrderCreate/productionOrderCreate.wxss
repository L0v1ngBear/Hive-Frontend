page {
  background-color: #f7f8fa;
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
  box-sizing: border-box;
  height: 100vh;
  padding-top: 0 !important; 
  margin: 0 !important;
  overflow: hidden;
}

.container {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  padding: 0 !important; 
  margin: 0 !important;
}

/* 顶部导航 - 完美适配刘海屏 */
.top-nav {
  width: 100%;
  box-sizing: content-box;
  padding-top: max(env(safe-area-inset-top), 20px); 
  height: 88rpx; 
  background-color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  flex-shrink: 0;
  z-index: 100;
}

.nav-back {
  position: absolute;
  left: 20rpx;
  bottom: 0;
  height: 88rpx;
  width: 80rpx;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  padding-left: 10rpx;
}

.back-icon { 
  font-size: 40rpx;
  color: #333;
}

.nav-title { 
  font-size: 34rpx; 
  font-weight: 600; 
  color: #333; 
}

/* 滚动区域 */
.form-scroll-container {
  flex: 1;
  width: 100%;
  box-sizing: border-box;
}

/* 卡片样式 */
.form-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 0 30rpx 10rpx;
  margin: 20rpx 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.02);
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  padding: 30rpx 0 20rpx;
  border-bottom: 1rpx solid #f5f5f5;
  margin-bottom: 10rpx;
}

/* 表单项通用样式 */
.form-item {
  display: flex;
  align-items: center;
  min-height: 100rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.form-item:last-child {
  border-bottom: none;
}

/* 左右分栏排列，适用于克重/规格同行显示 */
.form-row {
  display: flex;
  gap: 20rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.form-row .form-item {
  flex: 1;
  border-bottom: none;
}

.form-row .form-item .form-label {
  min-width: 120rpx; /* 减小同行的 label 宽度 */
}

.form-label {
  min-width: 200rpx;
  font-size: 28rpx;
  color: #333;
  flex-shrink: 0;
}

.required {
  color: #F5222D;
  margin-right: 4rpx;
}

/* 输入控件对齐 */
.form-input, .picker-view {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  text-align: right; 
  height: 80rpx;
  line-height: 80rpx;
}

.placeholder {
  color: #ccc;
}

/* 按钮区域 */
.fixed-bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  padding: 24rpx 30rpx calc(24rpx + env(safe-area-inset-bottom));
  background-color: #ffffff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
  display: flex;
  gap: 24rpx;
  z-index: 100;
  box-sizing: border-box;
}

.btn {
  flex: 1;
  height: 92rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  font-size: 30rpx;
  font-weight: 500;
  border-radius: 46rpx;
}

.btn-cancel {
  background-color: #f5f5f5;
  color: #666;
}

.btn-submit {
  background: linear-gradient(135deg, #1890FF, #0050B3);
  color: #ffffff;
  box-shadow: 0 6rpx 12rpx rgba(24, 144, 255, 0.3);
}

.safe-bottom-area {
  height: 220rpx; /* 留出足够空间不被底部栏遮挡 */
}