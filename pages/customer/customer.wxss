/* 基础重置，确保没有奇怪的边距 */
page {
  background-color: #F7F8FA;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, sans-serif;
}

.container {
  width: 100%;
  padding: 45px 12px;
  padding-bottom: 20px;
  min-height: 100%; /* 确保容器至少与屏幕等高 */
  display: flex;
  flex-direction: column;
}
.back-icon, .scan-icon {
  width: 24px;
  height: 24px;
}
/* ============ 头部重构 ============ */
.header-wrapper {
  background: #FFFFFF;
  width: 100%;
  box-sizing: border-box;
  /* 预留出系统状态栏高度，如果页面没顶到最上面，可以适当减小这个 padding-top */
  padding-top: 0rpx; 
  padding-bottom: 20rpx;
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.03);
  /* 底部增加极其微弱的圆角，更显高级 */
  border-radius: 0 0 24rpx 24rpx; 
}

/* 第一行：标题栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 80rpx;
  padding: 0 30rpx;
}

.nav-back {
  width: 60rpx;
  height: 100%;
  display: flex;
  align-items: center;
}

/* 纯 CSS 画的返回箭头，比图片更清晰锐利 */
.back-arrow {
  width: 20rpx;
  height: 20rpx;
  border-left: 4rpx solid #333;
  border-bottom: 4rpx solid #333;
  transform: rotate(45deg);
}

.nav-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.nav-right-placeholder {
  width: 60rpx; /* 与 nav-back 对称，保证标题绝对居中 */
}

/* 第二行：操作栏 */
.action-bar {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx 10rpx;
}

.search-box {
  flex: 1;
  display: flex;
  align-items: center;
  background: #F2F3F6;
  height: 72rpx;
  border-radius: 36rpx;
  padding: 0 24rpx;
  margin-right: 24rpx;
}

.search-box input {
  flex: 1;
  margin-left: 12rpx;
  font-size: 28rpx;
  color: #333;
}

.ph-style {
  color: #B0B5BF;
}

/* 新增按钮 */
.btn-add {
  margin: 0 !important;
  padding: 0 32rpx !important;
  height: 72rpx;
  line-height: 72rpx;
  background: linear-gradient(135deg, #FFC000, #FFA000);
  color: #FFF;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.add-icon {
  font-size: 32rpx;
  margin-right: 6rpx;
  font-weight: bold;
  /* margin-top: -4rpx; */
}

/* ============ 列表与卡片区域 ============ */
.customer-list {
  flex: 1;
  padding: 24rpx 0 60rpx;
}

.customer-card {
  background: #FFF;
  margin: 0 rpx 24rpx;
  padding: 30rpx;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.02);
}

.card-hover {
  background: #FAFAFA;
}

/* 修复后的标签对齐 */
.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #F5F6F8;
}

.header-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.company-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A1A;
}

/* 标签：高度压缩，上下居中，字体缩小 */
.customer-tag {
  font-size: 20rpx;
  padding: 6rpx 12rpx;
  border-radius: 8rpx;
  margin-left: 16rpx;
  font-weight: 500;
  line-height: 1; /* 去除字体自带的上下留白 */
  display: flex;
  align-items: center;
  justify-content: center;
}

.tag-blue { background: #EAF3FF; color: #2979FF; }
.tag-orange { background: #FFF4E6; color: #FF9900; }

.arrow-right {
  width: 12rpx;
  height: 12rpx;
  border-right: 3rpx solid #C0C4CC;
  border-top: 3rpx solid #C0C4CC;
  transform: rotate(45deg);
}

/* 数据排版 */
.data-row {
  display: flex;
  margin-bottom: 24rpx;
}

.data-item {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.data-label {
  font-size: 24rpx;
  color: #888;
  margin-bottom: 12rpx;
}

.data-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.highlight {
  color: #FFA000;
  font-size: 30rpx;
  font-weight: bold;
}

/* 底部灰色框 */
.project-row {
  background: #F7F8FA;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  display: flex;
  align-items: center;
}

.project-label {
  color: #999;
}

.project-name {
  color: #444;
  flex: 1;
}

.empty-holder {
  text-align: center;
  padding-top: 100rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #CCC;
}