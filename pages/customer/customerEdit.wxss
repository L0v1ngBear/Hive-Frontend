.container {
  padding: 50px 12px;
  padding-bottom: 20px;
  background: #f8f8f8;
  min-height: 100vh;
}

.section {
  background: #fff;
  border-radius: 12rpx;
  padding: 25rpx;
  margin-bottom: 30rpx;
}
.container {
  width: 100%;
  padding: 45px 12px;
  padding-bottom: 20px;
  min-height: 100%; /* 确保容器至少与屏幕等高 */
  display: flex;
  flex-direction: column;
}
.back-icon, .scan-icon {
  width: 24px;
  height: 24px;
}
/* ============ 头部重构 ============ */
.header-wrapper {
  background: #FFFFFF;
  width: 100%;
  box-sizing: border-box;
  /* 预留出系统状态栏高度，如果页面没顶到最上面，可以适当减小这个 padding-top */
  padding-top: 0rpx; 
  padding-bottom: 20rpx;
  position: sticky;
  margin-bottom: 20rpx; /* 距离下方 20rpx */
  margin-top: 20rpx; /* 距离下方 20rpx */
  top: 0;
  z-index: 100;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.03);
  /* 底部增加极其微弱的圆角，更显高级 */
  border-radius: 0 0 24rpx 24rpx; 
}

/* 第一行：标题栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 60rpx;
  padding: 0 30rpx;
}

.nav-back {
  width: 60rpx;
  height: 100%;
  display: flex;
  align-items: center;
}



.nav-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.nav-right-placeholder {
  width: 60rpx; /* 与 nav-back 对称，保证标题绝对居中 */
}
.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  padding-bottom: 10rpx;
  border-bottom: 10rpx solid #eee;
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.form-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.label {
  width: 160rpx;
  font-size: 28rpx;
  color: #666;
}

.add-btn {
  color: #07c160;
  font-size: 28rpx;
}

.contact-group {
  background: #fafafa;
  padding: 10rpx;
  margin-top: 10rpx;
  border-radius: 8rpx;
}

.submit-btn {
  margin-top: 50rpx;
  width: 100%;
  border-radius: 44rpx;
}

.picker {
  font-size: 28rpx;
  color: #333;
}