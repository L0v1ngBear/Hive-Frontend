<view class="container">
  <view class="header-wrapper">
    <view class="nav-bar">
      <view class="nav-back" bindtap="handleBack">
        <image class="back-icon" src="/images/back.png"></image>
      </view>
      <view class="nav-title">新增客户</view>
      <view class="nav-right-placeholder"></view> </view>
  </view>
  <form bindsubmit="handleFormSubmit">
    <view class="section">
      <view class="section-title">基础信息</view>
      <view class="form-item">
        <text class="label">公司名称</text>
        <input name="companyName" placeholder="请输入公司全称" />
      </view>
      <view class="form-item">
        <text class="label">客户类型</text>
        <picker bindchange="handleTypeChange" value="{{typeIndex}}" range="{{typeRange}}">
          <view class="picker">{{typeRange[typeIndex]}}</view>
        </picker>
      </view>
      <view class="form-item">
        <text class="label">施工区域</text>
        <input name="region" placeholder="省份/城市" />
      </view>
    </view>

    <view class="section">
      <view class="section-title flex-between">
        <text>采购联系人</text>
        <text class="add-btn" bindtap="handleAddContact">+ 添加</text>
      </view>
      <block wx:for="{{contacts}}" wx:key="index">
        <view class="contact-group">
          <view class="form-item">
            <input placeholder="姓名" data-index="{{index}}" data-field="name" bindinput="handleContactInput" value="{{item.name}}" />
            <input placeholder="电话" type="number" data-index="{{index}}" data-field="phone" bindinput="handleContactInput" value="{{item.phone}}" />
            <icon wx:if="{{contacts.length > 1}}" type="clear" size="20" bindtap="handleRemoveContact" data-index="{{index}}" />
          </view>
        </view>
      </block>
    </view>

    <view class="section">
      <view class="section-title">合作信息</view>
      <view class="form-item">
        <text class="label">合作项目</text>
        <input name="projectName" placeholder="最近合作项目名称" />
      </view>
      <view class="form-item">
        <text class="label">项目数量</text>
        <input name="projectCount" type="number" placeholder="累计合作数量" />
      </view>
    </view>

    <button class="submit-btn" form-type="submit" type="primary">提交保存</button>
  </form>
</view>