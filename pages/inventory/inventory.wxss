/* pages/inventory/inventory.wxss */
page {
  background-color: #fafafa;
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
  padding-top: env(safe-area-inset-top);
  box-sizing: border-box;
  height: 100vh;
  overflow: hidden;
}

/* 滚动容器 */
.scroll-container {
  width: 100%;
  height: 100%;
  scrollbar-width: none;
  -ms-overflow-style: none;
}
.scroll-container::-webkit-scrollbar {
  display: none;
}

/* 根容器：改用 Flex 布局以分配剩余空间 */
.container {
  width: 100%;
  min-height: 100%; /* 确保容器至少与屏幕等高 */
  padding: 45px 12px;
  padding-bottom: 20px;
  box-sizing: border-box;
  display: flex;
  flex-direction: column; /* 垂直排列 */
}

/* 顶部导航：与内容块左对齐 */
.top-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 0;
  margin-bottom: 12px;
  width: calc(100% - 24px);
  margin-left: auto;
  margin-right: auto;
  flex-shrink: 0;
}
.nav-back {
  width: 36px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: all 0.2s ease;
}
.nav-back-hover, .nav-back:active {
  background-color: #f5f5f5;
  transform: scale(0.95);
}
.back-icon, .scan-icon {
  width: 24px;
  height: 24px;
}
.nav-title {
  font-size: 18px;
  font-weight: 600;
  color: #333;
}
.nav-scan {
  width: 36px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: all 0.2s ease;
}
.nav-scan-hover, .nav-scan:active {
  background-color: #f5f5f5;
  transform: scale(0.95);
}

/* 统一内容块样式：缩小间距 */
.warning-section, .chart-section, .quick-actions, .record-section {
  width: 100%;
  border-radius: 16px;
  margin-bottom: 10px; /* 间距变小，更紧凑 */
  box-sizing: border-box;
  flex-shrink: 0;
}

/* ================= 1. 异常预警区域 ================= */
.warning-section {
  background: #FFF2F0;
  border: 1px solid #FFCCC7;
  padding: 12px 16px;
}
.warning-header {
  display: flex;
  align-items: center;
  margin-bottom: 6px;
}
.warning-title {
  font-size: 14px;
  font-weight: bold;
  color: #F5222D;
  margin-left: 8px;
}
.warning-swiper {
  height: 32px;
}
.warning-item {
  display: flex;
  align-items: center;
  font-size: 13px;
  color: #666;
  height: 100%;
}
.w-model {
  font-weight: bold;
  color: #333;
  margin-right: 10px;
}

/* ================= 2. 出入库趋势看板 (缩小面积) ================= */
.chart-section {
  background-color: #fff;
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.04);
  padding: 16px 20px; /* 减小内边距 */
}
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px; /* 减小标题与图表的间距 */
}
.section-title {
  font-size: 16px;
  font-weight: 600;
  color: #333;
}
.chart-legend {
  display: flex;
  gap: 16px;
}
.legend-item {
  display: flex;
  align-items: center;
  font-size: 12px;
  color: #666;
}
.dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  margin-right: 6px;
}
.dot.in { background-color: #1890FF; } 
.dot.out { background-color: #52C41A; } 
.chart-container {
  width: 100%;
  height: 240rpx; /* 高度从 360rpx 缩小到 240rpx */
  position: relative;
}
.trend-canvas {
  width: 100%;
  height: 100%;
}

/* ================= 3. 快捷操作区 (放大面积) ================= */
.quick-actions {
  background-color: #fff;
  padding: 24px 10px; /* 增加上下内边距，让区域变大 */
  display: flex;
  justify-content: space-around;
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.04);
}
.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 90px; /* 增加整体项的宽度 */
  transition: all 0.2s ease;
}
.action-item:active {
  transform: scale(0.95);
  opacity: 0.8;
}
.action-icon-wrapper {
  width: 72px;  /* 从 56px 放大到 72px */
  height: 72px; /* 从 56px 放大到 72px */
  border-radius: 20px; /* 圆角稍微改大适应新尺寸 */
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12px; /* 增加图标和文字之间的间距 */
}
.action-icon {
  width: 38px;  /* 图标从 28px 放大到 38px */
  height: 38px; 
}
.action-text {
  font-size: 15px; /* 文字从 13px 放大到 15px */
  font-weight: 500; /* 文字稍微加粗 */
  color: #333;
}

/* ================= 4. 操作记录区域：填满底部空间 ================= */
.record-section {
  background-color: #fff;
  padding: 20px;
  flex: 1; /* 占据剩余垂直空间 */
  margin-bottom: 0;
  display: flex;
  flex-direction: column;
  box-shadow: 0 -2px 12px rgba(0, 0, 0, 0.02);
}
.section-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16px;
  flex-shrink: 0;
}
.section-title text:first-child {
  font-size: 18px;
  font-weight: 600;
  color: #333;
}
.section-title text:last-child {
  font-size: 15px;
  color: #999;
}

/* 记录列表 & 表格优化 */
.record-list {
  width: 100%;
  flex: 1; 
}
.record-header {
  display: flex;
  align-items: center;
  padding: 12px 8px;
  border-bottom: 1px solid #e0e0e0;
  margin-bottom: 8px;
  background-color: #f7f8fa;
  border-radius: 6px;
}
.record-item {
  display: flex;
  align-items: center;
  padding: 12px 8px;
  border-bottom: 1px solid #ebebeb;
  transition: background-color 0.2s;
}
.record-item:last-child {
  border-bottom: none;
}
.record-item:active {
  background-color: #fcfcfc;
}
.header-col, .record-col {
  font-size: 15px;
  word-break: break-all;
  box-sizing: border-box;
  padding: 0 4px;
}
.header-col {
  color: #999;
  font-weight: 500;
}
.record-col {
  color: #333;
}
.time-col { flex: 1.5; text-align: left; }
.type-col { flex: 0.8; text-align: center; }
.model-col { flex: 1.8; text-align: center; }
.meter-col { flex: 0.8; text-align: right; padding-right: 8px; }

.type-in { color: #52C41A; font-weight: 500; }
.type-out { color: #F5222D; font-weight: 500; }

.stopPropagation { pointer-events: auto; }

/* ================= 弹窗公共样式优化 (原样保留) ================= */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}
.modal-content {
  width: 85%;
  max-width: 600rpx;
  background: #fff;
  border-radius: 24rpx; 
  padding: 40rpx 30rpx;
  box-sizing: border-box;
}
.modal-content.add-cloth-modal {
  max-width: 600rpx;
  max-height: 80vh;
  overflow-y: auto;
}
.modal-title {
  font-size: 34rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 30rpx;
  color: #333;
}
.info-row {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  position: relative;
}
.info-row text {
  font-size: 28rpx;
  color: #666;
  min-width: 140rpx;
}
.info-row input {
  flex: 1;
  height: 76rpx;
  border: 1px solid #e8e8e8;
  border-radius: 12rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #333;
  background-color: #fafafa;
}
.model-list {
  position: absolute;
  top: 84rpx;
  left: 140rpx;
  right: 0;
  background: #fff;
  border: 1px solid #f5f5f5;
  border-radius: 12rpx;
  box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
  max-height: 240rpx;
  overflow-y: auto;
  z-index: 1000;
}
.model-item {
  padding: 16rpx 24rpx;
  border-bottom: 1px solid #f9f9f9;
  font-size: 28rpx;
  color: #333;
  transition: all 0.2s ease;
}
.model-item:last-child {
  border-bottom: none;
}
.model-item.create-item {
  color: #F5A623;
  font-weight: 500;
}
.model-item:active {
  background-color: #f0f0f0;
}
.modal-info {
  display: flex;
  margin-bottom: 20rpx;
  font-size: 28rpx;
}
.info-label {
  color: #666;
  width: 120rpx;
}
.info-value {
  color: #333;
  flex: 1;
  word-break: break-all;
}
.modal-actions, .oper-btns, .print-type-btns {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
}
.modal-btn, .btn, .print-btn {
  flex: 1;
  padding: 0; 
  margin: 0;  
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 12rpx;
  font-size: 35rpx;
  border: none;
  font-weight: 500;
}
.cancel-btn, .btn.cancel {
  background: #f5f5f5;
  color: #666;
}
.confirm-btn, .btn.in {
  background: linear-gradient(90deg, #F5A623, #FFB84D);
  color: #fff;
}
.btn.out {
  background: #F5222D;
  color: #fff;
}
.print-type-btns {
  margin: 30rpx 0 20rpx 0;
}
.preview-btn {
  background: #0088ff;
  color: #fff;
}
.bluetooth-btn {
  background: #07c160;
  color: #fff;
}