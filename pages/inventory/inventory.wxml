<scroll-view class="scroll-container" scroll-y>
  <view class="container">
    <view class="top-nav">
      <view class="nav-back" bindtap="handleBack">
        <image class="back-icon" src="/images/back.png"></image>
      </view>
      <text class="nav-title">布匹库存管理</text>
      <view class="nav-scan" bindtap="handleScanCode">
        <image class="scan-icon" src="/images/scan.png"></image>
      </view>
    </view>

    <view class="inventory-overview">
      <view class="overview-title">库存概览</view>
      <view class="overview-stats">
        <view class="stat-item">
          <text class="stat-label">总匹数</text>
          <text class="stat-value">{{totalRollCount}}</text>
        </view>
        <view class="stat-item">
          <text class="stat-label">总米数</text>
          <text class="stat-value">{{totalMeters}}</text>
        </view>
        <view class="stat-item">
          <text class="stat-label">今日入库</text>
          <text class="stat-value in-stock">{{todayInMeters}}</text>
        </view>
        <view class="stat-item">
          <text class="stat-label">今日出库</text>
          <text class="stat-value out-stock">{{todayOutMeters}}</text>
        </view>
      </view>
    </view>

    <view class="quick-actions">
      <view class="action-item" bindtap="handleAddCloth">
        <image class="action-icon" src="/images/hand.png"></image>
        <text class="action-text">手动入库</text>
      </view>
      <view class="action-item" bindtap="handleScanCode">
        <image class="action-icon" src="/images/scan_all.png"></image>
        <text class="action-text">扫码出库</text>
      </view>
      <view class="action-item" bindtap="handleStockCheck">
        <image class="action-icon" src="/images/check.png"></image>
        <text class="action-text">布匹盘点</text>
      </view>
    </view>

    <view class="record-section">
      <view class="section-title">
        <text>最近操作</text>
        <text bindtap="handleShowAllRecord">查看全部</text>
      </view>

      <view class="record-list">
        <view class="record-header">
          <view class="header-col time-col">时间</view>
          <view class="header-col type-col">类型</view>
          <view class="header-col model-col">型号</view>
          <view class="header-col meter-col">米数</view>
        </view>

        <block wx:for="{{recordList}}" wx:key="id">
          <view class="record-item">
            <view class="record-col time-col">{{item.time}}</view>
            <view class="record-col type-col {{item.type === 'in' ? 'type-in' : 'type-out'}}">{{item.type === 'in' ? '入库' : '出库'}}</view>
            <view class="record-col model-col">{{item.model}}</view>
            <view class="record-col meter-col">{{item.meters}}m</view>
          </view>
        </block>
      </view>
    </view>
  </view>
</scroll-view>

<view class="modal-mask" wx:if="{{showClothModal}}" bindtap="hideClothModal">
  <view class="modal-content" catchtap="stopPropagation">
    <view class="modal-title">布匹信息</view>
    <view class="info-row">
      <text>条码：</text>
      <text>{{barcode}}</text>
    </view>
    <view class="info-row">
      <text>型号：</text>
      <text>{{clothInfo.model}}</text>
    </view>
    <view class="info-row">
      <text>当前米数：</text>
      <text>{{clothInfo.meters}} m</text>
    </view>
    <view class="info-row" wx:if="{{currentOperType === 'in'}}">
      <text>入库米数：</text>
      <input type="digit" bindinput="onMetersInput" placeholder="请输入米数" />
    </view>
    <view class="oper-btns">
      <button class="btn in" bindtap="doIn" wx:if="{{!clothInfo.isInStock}}">入库</button>
      <button class="btn out" bindtap="doOut" wx:if="{{clothInfo.isInStock}}">出库</button>
    </view>
  </view>
</view>

<view class="modal-mask" wx:if="{{showAddClothModal}}" bindtap="hideAddClothModal">
  <view class="modal-content add-cloth-modal" catchtap="stopPropagation">
    <view class="modal-title">新增布匹入库</view>

    <view class="info-row">
      <text>型号：</text>
      <input type="text" bindinput="onModelSearch" bindfocus="showModelList" placeholder="请输入" value="{{clothForm.model}}" />
      <view class="model-list" wx:if="{{showModelList && (modelOptions.length > 0 || clothForm.model.trim() !== '')}}">
        <view class="model-item" wx:for="{{modelOptions}}" wx:key="index" bindtap="chooseModel" data-model="{{item}}">
          {{item}}
        </view>
        <view class="model-item create-item" wx:if="{{modelOptions.length === 0 && clothForm.model.trim() !== ''}}" bindtap="createModel">
          新建型号：{{clothForm.model}}
        </view>
      </view>
    </view>

    <view class="info-row">
      <text>米数：</text>
      <input type="digit" bindinput="onFormInput" data-field="meters" placeholder="请输入入库米数" value="{{clothForm.meters}}" />
    </view>

    <view class="info-row">
      <text>门幅：</text>
      <input type="text" bindinput="onWidthInput" bindfocus="showWidthList" placeholder="请输入" value="{{clothForm.width}}" readonly="{{!!clothForm.width && modelHasWidth}}" />
      <view class="model-list" wx:if="{{showWidthList && widthOptions.length > 0}}">
        <view class="model-item" wx:for="{{widthOptions}}" wx:key="index" bindtap="chooseWidth" data-width="{{item}}">
          {{item}}
        </view>
      </view>
    </view>

    <view class="oper-btns">
      <button class="btn in" bindtap="doAddCloth">确认</button>
      <button class="btn cancel" bindtap="hideAddClothModal">取消</button>
    </view>
  </view>
</view>

<view class="modal-mask" wx:if="{{showPrintModal}}" bindtap="hidePrintModal">
  <view class="modal-content" catchtap="stopPropagation">
    <view class="modal-title">选择打印方式</view>
    <view class="modal-info">
      <text class="info-label">条码：</text>
      <text class="info-value">{{printData.barcode}}</text>
    </view>
    <view class="print-type-btns">
      <button class="print-btn preview-btn" bindtap="choosePrintType" data-type="preview">预览打印</button>
      <button class="print-btn bluetooth-btn" bindtap="choosePrintType" data-type="bluetooth">打印</button>
    </view>
    <button class="modal-btn cancel-btn" bindtap="hidePrintModal">取消</button>
  </view>
</view>