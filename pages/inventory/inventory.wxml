<scroll-view class="scroll-container" scroll-y>
  <view class="container">
    <view class="top-nav">
      <view class="nav-back" bindtap="handleBack">
        <image class="back-icon" src="/images/back.png"></image>
      </view>
      <text class="nav-title">智慧仓储看板</text>
      <view class="nav-scan" bindtap="handleScanCode">
        <image class="scan-icon" src="/images/scan.png"></image>
      </view>
    </view>

    <view class="warning-section" wx:if="{{lowStockList.length > 0}}">
      <view class="warning-header">
        <icon type="warn" size="18" color="#F5222D"></icon>
        <text class="warning-title">库存预警 ({{lowStockList.length}}条型号告急)</text>
      </view>
      <swiper class="warning-swiper" vertical autoplay circular interval="3000">
        <swiper-item wx:for="{{lowStockList}}" wx:key="modelCode">
          <view class="warning-item">
            <text class="w-model">{{item.modelCode}}</text>
            <text class="w-msg">当前余量 {{item.meters}}m，建议及时补货</text>
          </view>
        </swiper-item>
      </swiper>
    </view>

    <view class="chart-section">
      <view class="section-header">
        <text class="section-title">出入库趋势 (近7日)</text>
        <view class="chart-legend">
          <view class="legend-item"><view class="dot in"></view>入库</view>
          <view class="legend-item"><view class="dot out"></view>出库</view>
        </view>
      </view>
      <view class="chart-container">
        <canvas canvas-id="trendChart" class="trend-canvas"></canvas>
      </view>
    </view>

    <view class="quick-actions">
      <view class="action-item" bindtap="handleAddCloth">
        <view class="action-icon-wrapper hand">
          <image class="action-icon" src="/images/hand.png"></image>
        </view>
        <text class="action-text">手动入库</text>
      </view>
      <view class="action-item" bindtap="handleScanCode">
        <view class="action-icon-wrapper scan">
          <image class="action-icon" src="/images/scan_all.png"></image>
        </view>
        <text class="action-text">扫码出库</text>
      </view>
      <view class="action-item" bindtap="handleStockCheck">
        <view class="action-icon-wrapper check">
          <image class="action-icon" src="/images/check.png"></image>
        </view>
        <text class="action-text">布匹盘点</text>
      </view>
    </view>

    <view class="record-section">
      <view class="section-title">
        <text>最近操作记录</text>
        <text class="show-all" bindtap="handleShowAllRecord">查看全部</text>
      </view>

      <view class="record-list">
        <view class="record-header">
          <view class="header-col time-col">时间</view>
          <view class="header-col type-col">类型</view>
          <view class="header-col model-col">型号</view>
          <view class="header-col meter-col">米数</view>
        </view>

        <block wx:for="{{recordList}}" wx:key="id">
          <view class="record-item">
            <view class="record-col time-col">{{item.time}}</view>
            <view class="record-col type-col {{item.type === 'in' ? 'type-in' : 'type-out'}}">
              {{item.type === 'in' ? '入库' : '出库'}}
            </view>
            <view class="record-col model-col">{{item.model}}</view>
            <view class="record-col meter-col">{{item.meters}}m</view>
          </view>
        </block>
        
        <view class="empty-tip" wx:if="{{recordList.length === 0}}">暂无操作记录</view>
      </view>
    </view>
  </view>
</scroll-view>

<view class="modal-mask" wx:if="{{showClothModal}}" bindtap="hideClothModal">
  <view class="modal-content" catchtap="stopPropagation">
    <view class="modal-title">布匹信息</view>
    <view class="info-row-display"><text class="label">条码：</text><text class="value">{{barcode}}</text></view>
    <view class="info-row-display"><text class="label">型号：</text><text class="value">{{clothInfo.model || clothInfo.modelCode}}</text></view>
    <view class="info-row-display"><text class="label">当前规格：</text><text class="value">{{clothInfo.spec}}</text></view>
    <view class="info-row-display"><text class="label">当前米数：</text><text class="value">{{clothInfo.meters}} m</text></view>
    <view class="info-input-row">
      <text class="label">{{currentOperType === 'in' ? '入库米数：' : '出库米数：'}}</text>
      <input class="modal-input" type="digit" bindinput="onMetersInput" placeholder="请输入米数" value="{{inputMeters}}" focus />
    </view>
    <view class="oper-btns">
      <button class="btn in" bindtap="doIn" wx:if="{{currentOperType === 'in'}}">确认入库</button>
      <button class="btn out" bindtap="doOut" wx:if="{{currentOperType === 'out'}}">确认出库</button>
      <button class="btn cancel" bindtap="hideClothModal">取消</button>
    </view>
  </view>
</view>