<scroll-view class="scroll-container" scroll-y>
  <view class="container">
    <view class="top-nav">
      <view class="nav-back" bindtap="handleBack">
        <image class="back-icon" src="/images/back.png"></image>
      </view>
      <text class="nav-title">布匹库存管理</text>
      <view class="nav-scan" bindtap="handleScanCode">
        <image class="scan-icon" src="/images/scan.png"></image>
      </view>
    </view>

    <view class="inventory-overview">
      <view class="overview-title">库存概览</view>
      <view class="overview-stats">
        <view class="stat-item">
          <text class="stat-label">总匹数</text>
          <text class="stat-value">{{totalRollCount}}</text>
        </view>
        <view class="stat-item">
          <text class="stat-label">总米数</text>
          <text class="stat-value">{{totalMeters}}</text>
        </view>
        <view class="stat-item">
          <text class="stat-label">今日入库</text>
          <text class="stat-value in-stock">{{todayInMeters}}</text>
        </view>
        <view class="stat-item">
          <text class="stat-label">今日出库</text>
          <text class="stat-value out-stock">{{todayOutMeters}}</text>
        </view>
      </view>
    </view>

    <view class="quick-actions">
      <view class="action-item" bindtap="handleAddCloth">
        <image class="action-icon" src="/images/hand.png"></image>
        <text class="action-text">手动入库</text>
      </view>
      <view class="action-item" bindtap="handleScanCode">
        <image class="action-icon" src="/images/scan_all.png"></image>
        <text class="action-text">扫码出库</text>
      </view>
      <view class="action-item" bindtap="handleStockCheck">
        <image class="action-icon" src="/images/check.png"></image>
        <text class="action-text">布匹盘点</text>
      </view>
    </view>

    <view class="record-section">
      <view class="section-title">
        <text>最近操作</text>
        <text class="show-all" bindtap="handleShowAllRecord">查看全部</text>
      </view>

      <view class="record-list">
        <view class="record-header">
          <view class="header-col time-col">时间</view>
          <view class="header-col type-col">类型</view>
          <view class="header-col model-col">型号</view>
          <view class="header-col meter-col">米数</view>
        </view>

        <block wx:for="{{recordList}}" wx:key="id">
          <view class="record-item">
            <view class="record-col time-col">{{item.time}}</view>
            <view class="record-col type-col {{item.type === 'in' ? 'type-in' : 'type-out'}}">
              {{item.type === 'in' ? '入库' : '出库'}}
            </view>
            <view class="record-col model-col">{{item.model}}</view>
            <view class="record-col meter-col">{{item.meters}}m</view>
          </view>
        </block>
        
        <view class="empty-tip" wx:if="{{recordList.length === 0}}">暂无操作记录</view>
      </view>
    </view>
  </view>
</scroll-view>

<view class="modal-mask" wx:if="{{showClothModal}}" bindtap="hideClothModal">
  <view class="modal-content" catchtap="stopPropagation">
    <view class="modal-title">布匹信息</view>
    <view class="info-row-display">
      <text class="label">条码：</text>
      <text class="value">{{barcode}}</text>
    </view>
    <view class="info-row-display">
      <text class="label">型号：</text>
      <text class="value">{{clothInfo.model || clothInfo.modelCode}}</text>
    </view>
    <view class="info-row-display">
      <text class="label">当前规格：</text>
      <text class="value">{{clothInfo.spec}}</text>
    </view>
    <view class="info-row-display">
      <text class="label">当前米数：</text>
      <text class="value">{{clothInfo.meters}} m</text>
    </view>
    
    <view class="info-input-row">
      <text class="label">{{currentOperType === 'in' ? '入库米数：' : '出库米数：'}}</text>
      <input class="modal-input" type="digit" bindinput="onMetersInput" placeholder="请输入米数" value="{{inputMeters}}" focus />
    </view>

    <view class="oper-btns">
      <button class="btn in" bindtap="doIn" wx:if="{{currentOperType === 'in'}}">确认入库</button>
      <button class="btn out" bindtap="doOut" wx:if="{{currentOperType === 'out'}}">确认出库</button>
      <button class="btn cancel" bindtap="hideClothModal">取消</button>
    </view>
  </view>
</view>

<view class="modal-mask" wx:if="{{showAddClothModal}}" bindtap="hideAddClothModal">
  <view class="modal-content add-cloth-modal" catchtap="stopPropagation">
    <view class="modal-title">新增布匹入库</view>

    <view class="info-row">
      <text class="label">型号：</text>
      <view class="input-container">
        <input class="modal-input" type="text" 
               bindinput="onModelSearch" 
               placeholder="输入型号搜索" 
               value="{{clothForm.modelCode}}" />
        
        <view class="model-list" wx:if="{{showModelList && modelOptions.length > 0}}">
          <view class="model-item" 
                wx:for="{{modelOptions}}" 
                wx:key="index" 
                bindtap="chooseModel" 
                data-model="{{item.modelCode}}" 
                data-spec="{{item.spec}}">
            <text class="m-code">{{item.modelCode}}</text>
            <text class="m-spec">规格: {{item.spec}}</text>
          </view>
        </view>
      </view>
    </view>

    <view class="info-row">
      <text class="label">米数：</text>
      <input class="modal-input" type="digit" 
             bindinput="onFormInput" 
             data-field="meters" 
             placeholder="请输入米数" 
             value="{{clothForm.meters}}" />
    </view>

    <view class="info-row">
      <text class="label">规格：</text>
      <input class="modal-input" type="digit" 
             bindinput="onFormInput" 
             data-field="spec" 
             placeholder="请输入规格(如门幅)" 
             value="{{clothForm.spec}}" />
    </view>

    <view class="oper-btns">
      <button class="btn in" bindtap="doAddCloth">确认提交</button>
      <button class="btn cancel" bindtap="hideAddClothModal">取消</button>
    </view>
  </view>
</view>

<view class="modal-mask" wx:if="{{showPrintModal}}" bindtap="hidePrintModal">
  <view class="modal-content" catchtap="stopPropagation">
    <view class="modal-title">入库成功</view>
    <view class="modal-info">
      <view class="info-line"><text>条码：</text><text>{{printData.barcode}}</text></view>
      <view class="info-line"><text>型号：</text><text>{{printData.modelCode}}</text></view>
    </view>
    <view class="print-type-btns">
      <button class="print-btn preview-btn" bindtap="choosePrintType" data-type="preview">预览标签</button>
      <button class="print-btn bluetooth-btn" bindtap="choosePrintType" data-type="bluetooth">蓝牙打印</button>
    </view>
    <button class="modal-btn cancel-btn" bindtap="hidePrintModal">关闭</button>
  </view>
</view>