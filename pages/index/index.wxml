<scroll-view class="scroll-container" scroll-y="true">
  <view class="fixed-top-nav-wrap">
    <view class="top-nav">
      <view class="nav-left">
        <image class="nav-icon" src="/images/hive.png" mode="widthFix" lazy-load="true"></image>
        <text class="tenant-name" selectable="false">
          {{tenantInfo.name || '当前组织'}}
        </text>
      </view>
      
      <view class="nav-scan-btn" bindtap="handleScanWebLogin" hover-class="nav-scan-btn-hover">
        <image class="nav-scan-icon" src="/images/scan_all.png" mode="aspectFit"></image>
      </view>
    </view>
  </view>

  <view class="container">
    <view class="user-card">
      <view class="user-avatar-wrapper">
        <image class="user-avatar" src="/images/avatar.png" mode="widthFix" lazy-load="true"></image>
      </view>
      <view class="user-info">
        <text class="user-name" selectable="false">{{userInfo.name}}</text>
        <text class="user-dept" selectable="false">{{userInfo.dept}}</text>
        <text class="user-tenant" selectable="false">{{tenantInfo.name || '当前未绑定组织'}}</text>
      </view>
      <view class="user-todo" bindtap="handleJumpToTodoList">
        <text class="todo-num" selectable="false">{{todoCount}}</text>
        <text class="todo-text" selectable="false">待办事项</text>
      </view>
    </view>

    <view class="function-module">
      <view class="module-title" selectable="false">核心功能</view>
      <view class="function-grid">
        <view class="grid-item" bindtap="handleFunctionTap" data-function-type="attendance" hover-class="grid-item-hover">
          <image class="grid-icon" src="/images/attendance.png" mode="widthFix" lazy-load="true"></image>
          <text class="grid-text" selectable="false">考勤打卡</text>
        </view>
        <view class="grid-item" bindtap="handleFunctionTap" data-function-type="order" hover-class="grid-item-hover">
          <image class="grid-icon" src="/images/order.png" mode="widthFix" lazy-load="true"></image>
          <text class="grid-text" selectable="false">生产订单</text>
        </view>
        <view class="grid-item" bindtap="handleFunctionTap" data-function-type="salesOrder" hover-class="grid-item-hover">
          <image class="grid-icon" src="/images/order.png" mode="widthFix" lazy-load="true"></image>
          <text class="grid-text" selectable="false">销售订单</text>
        </view>
        <view class="grid-item" bindtap="handleFunctionTap" data-function-type="inventory" hover-class="grid-item-hover">
          <image class="grid-icon" src="/images/inventory.png" mode="widthFix" lazy-load="true"></image>
          <text class="grid-text" selectable="false">库存管理</text>
        </view>
        <view class="grid-item" bindtap="handleFunctionTap" data-function-type="badProduct" hover-class="grid-item-hover">
          <image class="grid-icon" src="/images/badproduct.png" mode="widthFix" lazy-load="true"></image>
          <text class="grid-text" selectable="false">坏品管理</text>
        </view>
        <view class="grid-item" bindtap="handleFunctionTap" data-function-type="approval" hover-class="grid-item-hover">
          <image class="grid-icon" src="/images/approval.png" mode="widthFix" lazy-load="true"></image>
          <text class="grid-text" selectable="false">审批流程</text>
        </view>
        <view class="grid-item" bindtap="handleFunctionTap" data-function-type="notice" hover-class="grid-item-hover">
          <image class="grid-icon" src="/images/notice.png" mode="widthFix" lazy-load="true"></image>
          <text class="grid-text" selectable="false">企业公告</text>
        </view>
      </view>
    </view>

    <view class="quick-todo">
      <view class="todo-title">
        <text selectable="false">待办列表</text>
        <text class="todo-more" bindtap="handleMoreTodo" hover-class="todo-more-hover">查看更多 ></text>
      </view>
      <view class="todo-list">
        <block wx:for="{{todoList}}" wx:key="id">
          <view class="todo-item" bindtap="handleTodoItemTap" data-item="{{item}}" hover-class="todo-item-hover">
            <view class="todo-tag" selectable="false">{{item.tag}}</view>
            <text class="todo-content" selectable="false" decode="{{true}}">{{item.content}}</text>
            <text class="todo-time" selectable="false">{{item.time}}</text>
          </view>
        </block>
        <view wx:if="{{todoList.length === 0}}" class="empty-todo">
          <text selectable="false">暂无待办事项</text>
        </view>
      </view>
    </view>

    <view class="bottom-tab">
      <view class="tab-item active" bindtap="switchTab" data-tab-page="index" hover-class="tab-item-hover">
        <image class="tab-icon" src="/images/home_active.png" mode="widthFix" lazy-load="true"></image>
        <text class="tab-text" selectable="false">首页</text>
      </view>
      <view class="tab-item" bindtap="switchTab" data-tab-page="mine" hover-class="tab-item-hover">
        <image class="tab-icon" src="/images/mine.png" mode="widthFix" lazy-load="true"></image>
        <text class="tab-text" selectable="false">我的</text>
      </view>
    </view>
  </view>
</scroll-view>