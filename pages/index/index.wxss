/* pages/index/index.wxss */
page {
  background-color: #fafafa;
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
  padding-top: env(safe-area-inset-top);
  box-sizing: border-box;
  height: 100vh;
  overflow: hidden;
}

/* 滚动容器 */
.scroll-container {
  width: 100%;
  height: 100%;
  scrollbar-width: none;
  -ms-overflow-style: none;
  padding-top: calc(64px + env(safe-area-inset-top));
  box-sizing: border-box;
}

.scroll-container::-webkit-scrollbar {
  display: none;
}

/* 固定顶部导航容器 */
.fixed-top-nav-wrap {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 999;
  background-color: #fafafa;
  padding-top: env(safe-area-inset-top);
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.03);
}

/* 顶部导航：优化为左右两端对齐 */
.top-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  /* 右侧 padding 设置为 105px，完美避开微信官方右上角的胶囊按钮 */
  padding: 12px 105px 12px 30px; 
  background: none;
  border: none;
  box-shadow: none;
  width: 100%;
  box-sizing: border-box;
}

.nav-left {
  display: flex;
  align-items: center;
  flex: 1;
  overflow: hidden;
}

.nav-icon {
  width: 40px;
  height: 40px;
  border-radius: 8px;
  margin-right: 12px;
  flex-shrink: 0;
}

/* 租户名称样式 */
.tenant-name {
  font-size: 18px;
  font-weight: 600;
  color: #333;
  letter-spacing: 0.5px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.tenant-name:active {
  opacity: 0.85;
}

/* =========================================
   新增：标准极简的顶部扫码按钮
========================================= */
.nav-scan-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36px;
  height: 36px;
  border-radius: 50%;
  background-color: #ffffff;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
  flex-shrink: 0;
  margin-left: 16px;
  transition: all 0.2s ease;
}

.nav-scan-btn-hover {
  background-color: #f5f5f5;
  transform: scale(0.92);
  box-shadow: 0 1px 4px rgba(0, 0, 0, 0.04);
}

.nav-scan-icon {
  width: 20px;
  height: 20px;
  opacity: 0.85;
}

/* 根容器 */
.container {
  width: 100%;
  padding: 0 30px;
  padding-bottom: calc(90px + env(safe-area-inset-bottom));
  box-sizing: border-box;
  overflow-y: auto;
  scrollbar-width: thin;
  scrollbar-color: rgba(251, 171, 6, 0.2) #f5f5f5;
  margin-top: 0;
}

.container::-webkit-scrollbar {
  width: 4px;
}

.container::-webkit-scrollbar-track {
  background-color: #f5f5f5;
  border-radius: 2px;
  margin: 16px 0;
}

.container::-webkit-scrollbar-thumb {
  background: linear-gradient(180deg, #fbab06, #fbc244);
  border-radius: 2px;
  transition: all 0.2s ease;
}

.container::-webkit-scrollbar-thumb:hover {
  background: linear-gradient(180deg, #e09905, #fbab06);
}

/* 用户信息卡片 */
.user-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28px 24px;
  margin: 0 0 24px;
  background-color: #ffffff;
  border-radius: 16px;
  box-shadow: 0 2px 12px rgba(251, 171, 6, 0.06);
  background: linear-gradient(180deg, #ffffff 0%, #FFFCF8 100%);
  box-sizing: border-box;
  width: 100%;
  max-width: 100%;
}

.user-avatar-wrapper {
  flex-shrink: 0;
}

.user-avatar {
  width: 64px;
  height: 64px;
  border-radius: 50%;
  border: 3px solid #FFF3E0;
  box-shadow: 0 2px 8px rgba(251, 171, 6, 0.1);
}

.user-info {
  flex: 1;
  margin: 0 20px;
  line-height: 1.4;
}

.user-name {
  display: block;
  font-size: 20px;
  font-weight: 600;
  color: #333333;
  margin-bottom: 6px;
  letter-spacing: 0.5px;
  -webkit-font-smoothing: antialiased;
}

.user-dept {
  font-size: 15px;
  color: #666666;
  line-height: 1.3;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  margin-bottom: 4px;
}

.user-tenant {
  font-size: 14px;
  color: #999;
  line-height: 1.3;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 待办事项模块 */
.user-todo {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 12px 16px;
  border-radius: 12px;
  background-color: #FFF9F0;
  flex-shrink: 0;
  cursor: pointer;
}

.todo-num {
  font-size: 32px;
  font-weight: bold;
  color: #fbab06;
  margin-bottom: 4px;
  text-shadow: 0 1px 2px rgba(251, 171, 6, 0.1);
}

.todo-text {
  font-size: 18px;
  color: #666666;
  opacity: 0.9;
  writing-mode: vertical-rl;
  text-orientation: mixed;
  letter-spacing: 3px;
}

/* 核心功能模块 */
.function-module {
  margin: 0 0 24px;
  width: 100%;
}

.module-title {
  font-size: 24px;
  font-weight: 600;
  color: #333333;
  margin-bottom: 16px;
  letter-spacing: 0.5px;
  -webkit-font-smoothing: antialiased;
  position: relative;
  padding-left: 10px;
}

.module-title::before {
  content: "";
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 4px;
  height: 20px;
  background-color: #fbab06;
  border-radius: 2px;
}

/* 核心功能块网格布局 */
.function-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-start;
  gap: 12px;
  padding: 16px;
  background-color: #ffffff;
  border-radius: 16px;
  box-shadow: 0 2px 12px rgba(251, 171, 6, 0.06);
  box-sizing: border-box;
  width: 100%;
  overflow: hidden;
}

.grid-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: calc(33.333% - 8px);
  height: 120px;
  padding: 12px 8px;
  box-sizing: border-box;
  border-radius: 12px;
  transition: all 0.2s ease-in-out;
  background-color: #FFFCF8;
}

.grid-icon {
  width: 48px;
  height: 48px;
  margin-right: 0;
  margin-bottom: 8px;
  filter: drop-shadow(0 2px 4px rgba(251, 171, 6, 0.1));
  border-radius: 8px;
}

.grid-text {
  font-size: 20px;
  color: #333333;
  font-weight: 500;
  -webkit-font-smoothing: antialiased;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 快捷待办 */
.quick-todo {
  margin: 0 0 24px;
  width: 100%;
}

.todo-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16px;
}

.todo-title text:first-child {
  font-size: 24px;
  font-weight: 600;
  color: #333333;
  letter-spacing: 0.5px;
  -webkit-font-smoothing: antialiased;
  position: relative;
  padding-left: 10px;
}

.todo-title text:first-child::before {
  content: "";
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 4px;
  height: 20px;
  background-color: #fbab06;
  border-radius: 2px;
}

.todo-more {
  font-size: 20px;
  color: #fbab06;
  text-decoration: none;
  transition: all 0.2s ease-in-out;
}

/* 待办列表 */
.todo-list {
  background-color: #ffffff;
  border-radius: 16px;
  box-shadow: 0 2px 12px rgba(251, 171, 6, 0.06);
  background: linear-gradient(180deg, #ffffff 0%, #FFFCF8 100%);
  overflow: hidden;
  width: 100%;
  box-sizing: border-box;
}

.todo-item {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  padding: 0 20px;
  height: 96px;
  border-bottom: 1px solid #f9f7f5;
  box-sizing: border-box;
  transition: all 0.2s ease-in-out;
  width: 100%;
  overflow: hidden;
}

.todo-item:last-child {
  border-bottom: none;
}

.todo-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 88px;
  height: 36px;
  background-color: #FFF3E0;
  color: #fbab06;
  font-size: 18px;
  border-radius: 18px;
  margin-right: 16px;
  font-weight: 500;
  box-shadow: 0 2px 4px rgba(251, 171, 6, 0.08);
  flex-shrink: 0;
  flex-grow: 0;
}

.todo-content {
  flex: 1;
  font-size: 22px;
  color: #333333;
  line-height: 1.4;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  -webkit-font-smoothing: antialiased;
  text-align: left;
}

.todo-time {
  font-size: 18px;
  color: #999999;
  margin-left: 16px;
  text-align: right;
  white-space: nowrap;
  flex-shrink: 0;
  flex-grow: 0;
  width: 100px;
  display: inline-block;
}

.empty-todo {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 96px;
  text-align: center;
  font-size: 22px;
  color: #999999;
  -webkit-font-smoothing: antialiased;
  background: linear-gradient(180deg, #ffffff 0%, #FFFCF8 100%);
}

/* 底部导航 */
.bottom-tab {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: 8px 0 calc(8px + env(safe-area-inset-bottom));
  background-color: #ffffff;
  box-shadow: 0 -2px 12px rgba(251, 171, 6, 0.06);
  z-index: 999;
  box-sizing: border-box;
  width: 100%;
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease-in-out;
  padding: 6px 12px;
}

.tab-item.active .tab-text {
  color: #fbab06;
  font-weight: 600;
}

.tab-item.active .tab-icon {
  filter: brightness(0.8) saturate(1.2) drop-shadow(0 2px 4px rgba(251, 171, 6, 0.2));
}

.tab-icon {
  width: 36px;
  height: 36px;
  margin-bottom: 4px;
  transition: all 0.2s ease-in-out;
}

.tab-text {
  font-size: 18px;
  color: #666666;
  transition: all 0.2s ease-in-out;
  -webkit-font-smoothing: antialiased;
}

/* 触摸反馈 */
.grid-item:active {
  opacity: 0.85;
  background-color: #FFFDFA;
  transform: scale(0.95);
}

.todo-more:active {
  opacity: 0.85;
  color: #e09905;
  text-decoration: underline;
}

.todo-item:active {
  background-color: #FFFDFA;
  transform: translateX(4px);
}

.tab-item:active {
  opacity: 0.85;
  transform: scale(0.98);
}

.user-todo:active {
  opacity: 0.9;
  transform: scale(0.98);
}

/* 测试时隐藏头部 */
.fixed-top-nav-wrap {
  display: none;
}

.scroll-container {
  padding-top: calc(12px + env(safe-area-inset-top));
}