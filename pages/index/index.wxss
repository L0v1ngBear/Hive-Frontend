/* --- 核心变量 --- */
page {
  --primary: #1f6fff;
  --primary-light: #eef6ff;
  --primary-dark: #071f5f;
  --bg: #f4f8ff;
  --white: #ffffff;
  --text-main: #071f5f;
  --text-sub: #64748b;
  --shadow: 0 10rpx 40rpx rgba(30, 41, 59, 0.05);
  --brand-icon-filter: brightness(0) saturate(100%) invert(40%) sepia(92%) saturate(2232%) hue-rotate(205deg) brightness(101%) contrast(102%);
  background-color: var(--bg);
}

/* --- 容器 --- */
.scroll-container {
  height: 100vh;
  width: 100%;
}

.main-content {
  padding: calc(85px + env(safe-area-inset-top)) 30rpx 40rpx;
}

/* --- 顶部导航：沉浸式透明渐变 --- */
.fixed-top-nav-wrap {
  position: fixed;
  top: 0;
  width: 100%;
  z-index: 1000;
  background: linear-gradient(180deg, rgba(31, 111, 255, 0.12) 0%, rgba(248, 250, 252, 0.95) 100%);
  backdrop-filter: blur(20px);
  padding-top: env(safe-area-inset-top);
}

.top-nav {
  height: 56px;
  display: flex;
  align-items: center;
  padding: 0 110px 0 32rpx;
}

.nav-search-bar {
  flex: 1;
  height: 38px;
  background: var(--white);
  border-radius: 19px;
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  border: 1rpx solid #f1f5f9;
}

.search-placeholder {
  font-size: 26rpx;
  color: var(--text-sub);
  margin-left: 12rpx;
}

.nav-scan-btn {
  width: 38px;
  height: 38px;
  background: var(--primary);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 16rpx;
  box-shadow: 0 6rpx 16rpx rgba(31, 111, 255, 0.3);
}

.nav-scan-icon {
  width: 20px;
  height: 20px;
  filter: brightness(0) invert(1);
}

/* --- 用户卡片 --- */
.user-card {
  background: var(--white);
  border-radius: 32rpx;
  padding: 44rpx 32rpx;
  box-shadow: var(--shadow);
  margin-bottom: 36rpx;
  position: relative;
  overflow: hidden;
}

.user-card-inner {
  display: flex;
  align-items: center;
  position: relative;
  z-index: 1;
}

.user-avatar {
  width: 108rpx;
  height: 108rpx;
  border-radius: 50%;
  border: 4rpx solid var(--white);
  box-shadow: 0 8rpx 16rpx rgba(0, 0, 0, 0.06);
}

.user-info {
  flex: 1;
  margin-left: 24rpx;
}

.user-name {
  font-size: 38rpx;
  font-weight: 800;
  color: var(--text-main);
}

.user-dept {
  font-size: 24rpx;
  color: var(--text-sub);
  margin-top: 6rpx;
}

.user-todo-badge {
  background: var(--primary);
  padding: 14rpx 22rpx;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 8rpx 24rpx rgba(31, 111, 255, 0.25);
}

.todo-num {
  font-size: 42rpx;
  font-weight: 800;
  color: var(--white);
  line-height: 1;
}

.todo-label {
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-top: 4rpx;
}

/* --- 核心功能 (82rpx 大图标) --- */
.section-title {
  font-size: 32rpx;
  font-weight: 800;
  color: var(--text-main);
  margin-bottom: 24rpx;
  padding-left: 16rpx;
  border-left: 8rpx solid var(--primary);
}

.function-grid {
  display: flex;
  flex-wrap: wrap;
  background: var(--white);
  border-radius: 32rpx;
  padding: 32rpx 10rpx;
  box-shadow: var(--shadow);
  margin-bottom: 36rpx;
}

.grid-item {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 26rpx 0;
}

.icon-wrap {
  width: 90rpx;
  height: 90rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 14rpx;
}

.grid-icon {
  width: 82rpx !important;
  height: 82rpx !important;
  filter: var(--brand-icon-filter) drop-shadow(0 4rpx 10rpx rgba(31, 111, 255, 0.12));
}

.grid-text {
  font-size: 25rpx;
  color: var(--text-main);
  font-weight: 500;
}

/* --- 待办事项美化版 --- */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.todo-more {
  font-size: 24rpx;
  color: var(--primary);
  font-weight: 600;
  display: flex;
  align-items: center;
  gap: 4rpx;
  padding: 6rpx 20rpx;
  background: var(--primary-light);
  border-radius: 20px;
}

.todo-card-item {
  position: relative;
  display: flex;
  align-items: center;
  background: var(--white);
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  padding: 32rpx 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.02);
  transition: all 0.3s ease;
  overflow: hidden;
}

.todo-status-bar {
  position: absolute;
  left: 0;
  top: 20%;
  bottom: 20%;
  width: 6rpx;
  background: var(--primary);
  border-radius: 0 4rpx 4rpx 0;
}

.todo-info-main {
  flex: 1;
  padding-left: 12rpx;
}

.todo-top-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.todo-tag-text {
  font-size: 18rpx;
  font-weight: 700;
  color: var(--primary);
  background: var(--primary-light);
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.todo-time-stamp {
  font-size: 22rpx;
  color: #94a3b8;
}

.todo-content-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #071f5f;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
}

.circle-btn {
  width: 32rpx;
  height: 32rpx;
  border: 3rpx solid #f1f5f9;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 20rpx;
}

.inner-dot {
  width: 10rpx;
  height: 10rpx;
  background: #cbd5e1;
  border-radius: 50%;
}

/* --- 底部导航及反馈 --- */
.bottom-tab-bar {
  position: fixed;
  bottom: 0;
  width: 100%;
  height: calc(105rpx + env(safe-area-inset-bottom));
  background: var(--white);
  display: flex;
  border-top: 1rpx solid #f1f5f9;
  z-index: 1000;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-bottom: env(safe-area-inset-bottom);
}

.tab-icon {
  width: 42rpx;
  height: 42rpx;
  filter: var(--brand-icon-filter);
}

.tab-item text {
  font-size: 20rpx;
  color: var(--text-sub);
  margin-top: 4rpx;
}

.tab-item.active text {
  color: var(--primary);
  font-weight: 800;
}

.todo-item-active {
  transform: scale(0.98);
  background: #f7fbff;
}

.btn-active-pulp {
  transform: scale(0.95);
  opacity: 0.8;
}

.footer-spacer {
  height: 160rpx;
}

.empty-txt {
  display: block;
  text-align: center;
  padding: 40rpx;
  color: #cbd5e1;
  font-size: 26rpx;
}
