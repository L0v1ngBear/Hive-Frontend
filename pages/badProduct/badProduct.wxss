page {
  min-height: 100vh;
  background:
    radial-gradient(circle at top, rgba(255, 184, 77, 0.2), transparent 36%),
    linear-gradient(180deg, #f6f8fc 0%, #ffffff 100%);
  color: #1f2937;
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
}

.page-scroll {
  height: 100vh;
}

.page-shell {
  box-sizing: border-box;
  max-width: 750rpx;
  padding: 28rpx 24rpx 40rpx;
}

.top-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.nav-action {
  width: 72rpx;
  height: 72rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 12rpx 24rpx rgba(15, 23, 42, 0.06);
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-action-primary {
  background: linear-gradient(135deg, #ffb84d 0%, #f59e0b 100%);
}

.nav-icon {
  width: 34rpx;
  height: 34rpx;
}

.nav-title {
  font-size: 36rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.hero-card,
.filter-card,
.state-card,
.record-card,
.popup-card {
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 16rpx 40rpx rgba(15, 23, 42, 0.06);
  border: 1rpx solid rgba(226, 232, 240, 0.9);
}

.hero-card {
  border-radius: 36rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.hero-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #0f172a;
}

.hero-desc {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #64748b;
}

.hero-badge {
  flex-shrink: 0;
  padding: 14rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(245, 158, 11, 0.12);
  color: #b45309;
  font-size: 24rpx;
  font-weight: 600;
}

.filter-card {
  border-radius: 32rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.filter-row + .filter-row {
  margin-top: 20rpx;
}

.filter-label {
  display: block;
  margin-bottom: 12rpx;
  font-size: 24rpx;
  color: #64748b;
  font-weight: 600;
}

.filter-pills {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.filter-pill {
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  background: #f8fafc;
  color: #475569;
  font-size: 24rpx;
}

.filter-pill.active {
  background: linear-gradient(135deg, #ffb84d 0%, #f59e0b 100%);
  color: #ffffff;
}

.date-picker {
  min-height: 84rpx;
  padding: 0 24rpx;
  border-radius: 24rpx;
  background: #f8fafc;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 26rpx;
  color: #334155;
}

.date-arrow {
  width: 24rpx;
  height: 24rpx;
}

.state-card {
  border-radius: 32rpx;
  padding: 100rpx 24rpx;
  text-align: center;
}

.state-text {
  font-size: 28rpx;
  color: #94a3b8;
}

.list-section {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.record-card {
  border-radius: 32rpx;
  padding: 28rpx;
}

.record-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.record-code {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #0f172a;
}

.record-time {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #94a3b8;
}

.record-status {
  flex-shrink: 0;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.record-status.pending {
  background: rgba(245, 158, 11, 0.12);
  color: #b45309;
}

.record-status.processed {
  background: rgba(34, 197, 94, 0.12);
  color: #15803d;
}

.record-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx 16rpx;
}

.record-field {
  padding: 18rpx;
  border-radius: 24rpx;
  background: #f8fafc;
}

.record-field.full {
  grid-column: 1 / -1;
}

.field-label {
  display: block;
  font-size: 22rpx;
  color: #94a3b8;
}

.field-value {
  display: block;
  margin-top: 10rpx;
  font-size: 26rpx;
  color: #0f172a;
  font-weight: 600;
}

.field-value.multi {
  line-height: 1.6;
  word-break: break-all;
}

.card-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  margin-top: 24rpx;
}

.action-btn {
  margin: 0;
  min-width: 168rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 700;
  border: none;
}

.action-btn::after,
.popup-btn::after {
  border: none;
}

.action-btn.secondary {
  background: #eef2ff;
  color: #1d4ed8;
}

.action-btn.primary {
  background: linear-gradient(135deg, #ffb84d 0%, #f59e0b 100%);
  color: #ffffff;
}

.popup-mask {
  position: fixed;
  inset: 0;
  background: rgba(15, 23, 42, 0.36);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  box-sizing: border-box;
  z-index: 99;
}

.popup-card {
  width: 100%;
  border-radius: 36rpx;
  padding: 30rpx;
  box-sizing: border-box;
}

.popup-header {
  margin-bottom: 24rpx;
}

.popup-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #0f172a;
}

.popup-subtitle {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #94a3b8;
}

.form-item + .form-item {
  margin-top: 20rpx;
}

.form-item.vertical .form-label {
  margin-bottom: 12rpx;
}

.form-label {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: #475569;
}

.form-input,
.form-picker,
.form-textarea {
  width: 100%;
  box-sizing: border-box;
  background: #f8fafc;
  border-radius: 24rpx;
  font-size: 26rpx;
  color: #0f172a;
}

.form-input,
.form-picker {
  min-height: 84rpx;
  padding: 0 24rpx;
  margin-top: 12rpx;
}

.form-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.form-textarea {
  min-height: 180rpx;
  padding: 20rpx 24rpx;
  margin-top: 12rpx;
}

.record-summary {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  padding: 20rpx 24rpx;
  border-radius: 24rpx;
  background: #f8fafc;
  color: #475569;
  font-size: 24rpx;
  margin-bottom: 20rpx;
}

.popup-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 28rpx;
}

.popup-btn {
  flex: 1;
  margin: 0;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 700;
  border: none;
}

.popup-btn.ghost {
  background: #eef2f7;
  color: #475569;
}

.popup-btn.solid {
  background: linear-gradient(135deg, #ffb84d 0%, #f59e0b 100%);
  color: #ffffff;
}

/* 统一视觉微调：避免次品页出现独立的蓝色按钮 */
.action-btn.secondary {
  background: #fff7e8;
  color: #d48806;
}
