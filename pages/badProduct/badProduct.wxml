<scroll-view class="page-scroll" scroll-y>
  <view class="page-shell">
    <view class="top-nav">
      <view class="nav-action" bindtap="handleBack">
        <image class="nav-icon" src="/images/back.png" mode="aspectFit" />
      </view>
      <text class="nav-title">次品管理</text>
      <view class="nav-action nav-action-primary" bindtap="openCreate">
        <image class="nav-icon" src="/images/add.png" mode="aspectFit" />
      </view>
    </view>

    <view class="hero-card">
      <view>
        <text class="hero-title">及时登记异常次品</text>
        <text class="hero-desc">支持筛选、编辑、处理和查看完整次品记录。</text>
      </view>
      <view class="hero-badge">{{list.length}} 条记录</view>
    </view>

    <view class="filter-card">
      <view class="filter-row">
        <text class="filter-label">状态</text>
        <view class="filter-pills">
          <view
            wx:for="{{statusOptions}}"
            wx:key="key"
            class="filter-pill {{currentStatus === item.key ? 'active' : ''}}"
            bindtap="handleStatusFilter"
            data-status="{{item.key}}"
          >
            {{item.label}}
          </view>
        </view>
      </view>

      <view class="filter-row">
        <text class="filter-label">类型</text>
        <view class="filter-pills">
          <view
            wx:for="{{typeOptions}}"
            wx:key="key"
            class="filter-pill {{currentType === item.key ? 'active' : ''}}"
            bindtap="handleTypeFilter"
            data-type="{{item.key}}"
          >
            {{item.label}}
          </view>
        </view>
      </view>

      <view class="filter-row">
        <text class="filter-label">日期</text>
        <picker mode="date" value="{{dateRange}}" start="2026-01-01" end="{{currentDate}}" bindchange="handleDateFilter">
          <view class="date-picker">
            <text>{{dateRange || '全部日期'}}</text>
            <image class="date-arrow" src="/images/arrow-down.png" mode="aspectFit" />
          </view>
        </picker>
      </view>
    </view>

    <view wx:if="{{loading}}" class="state-card">
      <text class="state-text">正在加载次品数据...</text>
    </view>

    <view wx:elif="{{list.length === 0}}" class="state-card">
      <text class="state-text">当前没有符合条件的次品记录</text>
    </view>

    <view wx:else class="list-section">
      <view wx:for="{{list}}" wx:key="defectiveId" class="record-card" bindtap="showDetail" data-record="{{item}}">
        <view class="record-head">
          <view>
            <text class="record-code">{{item.defectiveId}}</text>
            <text class="record-time">{{item.createTimeText}}</text>
          </view>
          <text class="record-status {{item.status}}">{{item.statusLabel}}</text>
        </view>

        <view class="record-grid">
          <view class="record-field">
            <text class="field-label">次品类型</text>
            <text class="field-value">{{item.typeLabel}}</text>
          </view>
          <view class="record-field">
            <text class="field-label">登记人</text>
            <text class="field-value">{{item.creatorText}}</text>
          </view>
          <view class="record-field">
            <text class="field-label">次品数量</text>
            <text class="field-value">{{item.quantityText}}</text>
          </view>
          <view class="record-field">
            <text class="field-label">损失金额</text>
            <text class="field-value">¥{{item.lossAmountText}}</text>
          </view>
          <view class="record-field full">
            <text class="field-label">关联订单</text>
            <text class="field-value">{{item.orderId || '未关联'}}</text>
          </view>
          <view class="record-field full">
            <text class="field-label">问题描述</text>
            <text class="field-value multi">{{item.description || '未填写'}}</text>
          </view>
        </view>

        <view class="card-actions">
          <button class="action-btn secondary" size="mini" catchtap="openEdit" data-record="{{item}}">编辑</button>
          <button
            wx:if="{{item.status !== 'processed'}}"
            class="action-btn primary"
            size="mini"
            catchtap="openProcess"
            data-record="{{item}}"
          >
            标记处理
          </button>
        </view>
      </view>
    </view>
  </view>
</scroll-view>

<view wx:if="{{showFormPopup}}" class="popup-mask" bindtap="closeFormPopup">
  <view class="popup-card" catchtap="stopPropagation">
    <view class="popup-header">
      <text class="popup-title">{{isEdit ? '编辑次品记录' : '新增次品记录'}}</text>
      <text class="popup-subtitle">保存后会直接写入真实次品台账</text>
    </view>

    <view class="form-item">
      <text class="form-label">关联订单</text>
      <input class="form-input" placeholder="请输入订单号" value="{{formData.orderId}}" bindinput="handleFormInput" data-key="orderId" />
    </view>

    <view class="form-item">
      <text class="form-label">次品类型</text>
      <picker value="{{typeIndex}}" range="{{typeLabels}}" bindchange="handleTypeChange">
        <view class="form-picker">
          <text>{{typeLabels[typeIndex] || '请选择次品类型'}}</text>
          <image class="date-arrow" src="/images/arrow-down.png" mode="aspectFit" />
        </view>
      </picker>
    </view>

    <view class="form-item">
      <text class="form-label">次品数量</text>
      <input class="form-input" type="digit" placeholder="请输入次品数量" value="{{formData.quantity}}" bindinput="handleFormInput" data-key="quantity" />
    </view>

    <view class="form-item">
      <text class="form-label">损失金额</text>
      <input class="form-input" type="digit" placeholder="请输入损失金额" value="{{formData.lossAmount}}" bindinput="handleFormInput" data-key="lossAmount" />
    </view>

    <view class="form-item vertical">
      <text class="form-label">问题描述</text>
      <textarea class="form-textarea" placeholder="请输入次品问题说明" value="{{formData.description}}" bindinput="handleFormInput" data-key="description" />
    </view>

    <view class="popup-actions">
      <button class="popup-btn ghost" bindtap="closeFormPopup">取消</button>
      <button class="popup-btn solid" bindtap="submitForm">{{isEdit ? '保存修改' : '确认登记'}}</button>
    </view>
  </view>
</view>

<view wx:if="{{showProcessPopup}}" class="popup-mask" bindtap="closeProcessPopup">
  <view class="popup-card" catchtap="stopPropagation">
    <view class="popup-header">
      <text class="popup-title">处理次品记录</text>
      <text class="popup-subtitle">处理后该次品会从待处理转为已处理</text>
    </view>

    <view class="record-summary" wx:if="{{currentRecord}}">
      <text>次品编号：{{currentRecord.defectiveId}}</text>
      <text>关联订单：{{currentRecord.orderId || '未关联'}}</text>
    </view>

    <view class="form-item">
      <text class="form-label">处理方式</text>
      <input class="form-input" placeholder="例如报废、返工、让步接收" value="{{processData.method}}" bindinput="handleProcessInput" data-key="method" />
    </view>

    <view class="form-item vertical">
      <text class="form-label">处理备注</text>
      <textarea class="form-textarea" placeholder="请输入处理说明" value="{{processData.remark}}" bindinput="handleProcessInput" data-key="remark" />
    </view>

    <view class="popup-actions">
      <button class="popup-btn ghost" bindtap="closeProcessPopup">取消</button>
      <button class="popup-btn solid" bindtap="submitProcess">确认处理</button>
    </view>
  </view>
</view>
