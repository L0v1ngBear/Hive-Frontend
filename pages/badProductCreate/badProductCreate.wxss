page {
  height: 100vh;
  min-height: 100vh;
  background:
    radial-gradient(circle at top right, rgba(103, 183, 255, 0.24), transparent 34%),
    linear-gradient(180deg, #f6f8fc 0%, #ffffff 100%);
  color: #1f2937;
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
  overflow: hidden;
}

.page-scroll {
  height: 100vh;
}

.page-shell {
  box-sizing: border-box;
  max-width: 750rpx;
  padding: 28rpx 24rpx 48rpx;
}

.top-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.nav-action,
.nav-placeholder {
  width: 72rpx;
  height: 72rpx;
}

.nav-action {
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 12rpx 24rpx rgba(15, 23, 42, 0.06);
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-icon {
  width: 34rpx;
  height: 34rpx;
}

.nav-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #071f5f;
}

.hero-card,
.form-card {
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid rgba(226, 232, 240, 0.9);
  box-shadow: 0 16rpx 40rpx rgba(15, 23, 42, 0.06);
}

.hero-card {
  border-radius: 36rpx;
  padding: 34rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 28rpx;
}

.hero-kicker {
  display: block;
  color: #0b2a6f;
  font-size: 20rpx;
  font-weight: 800;
  letter-spacing: 4rpx;
  text-transform: uppercase;
}

.hero-title {
  display: block;
  margin-top: 10rpx;
  font-size: 38rpx;
  font-weight: 900;
  color: #071f5f;
}

.hero-desc {
  display: block;
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #64748b;
}

.hero-mark {
  width: 112rpx;
  height: 112rpx;
  border-radius: 34rpx;
  background: linear-gradient(135deg, #67b7ff 0%, #1f6fff 100%);
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 18rpx 36rpx rgba(31, 111, 255, 0.28);
}

.form-card {
  border-radius: 36rpx;
  padding: 30rpx;
}

.form-item + .form-item,
.form-grid + .form-item {
  margin-top: 24rpx;
}

.form-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20rpx;
  margin-top: 24rpx;
}

.form-label {
  display: block;
  font-size: 24rpx;
  font-weight: 700;
  color: #475569;
  margin-bottom: 12rpx;
}

.form-input,
.form-picker,
.form-textarea {
  width: 100%;
  box-sizing: border-box;
  background: #f8fafc;
  border-radius: 24rpx;
  font-size: 26rpx;
  color: #071f5f;
}

.form-input,
.form-picker {
  min-height: 86rpx;
  padding: 0 24rpx;
}

.form-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.picker-arrow {
  width: 24rpx;
  height: 24rpx;
}

.form-textarea {
  min-height: 220rpx;
  padding: 22rpx 24rpx;
  line-height: 1.6;
}

.safe-bottom-area {
  height: 220rpx;
}

.bottom-actions {
  position: fixed;
  left: 0;
  bottom: 0;
  width: 100%;
  box-sizing: border-box;
  display: flex;
  gap: 18rpx;
  padding: 24rpx 30rpx calc(24rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.96);
  border-top: 1rpx solid rgba(226, 232, 240, 0.86);
  box-shadow: 0 -16rpx 44rpx rgba(15, 23, 42, 0.06);
  z-index: 100;
}

.action-btn {
  flex: 1;
  margin: 0;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 800;
  border: none;
}

.action-btn::after {
  border: none;
}

.action-btn.ghost {
  background: #eef2f7;
  color: #475569;
}

.action-btn.solid {
  background: linear-gradient(135deg, #67b7ff 0%, #1f6fff 100%);
  color: #ffffff;
  box-shadow: 0 16rpx 30rpx rgba(31, 111, 255, 0.28);
}
