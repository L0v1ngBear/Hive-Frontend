/* ================= 1. 基础重置与全局适配 ================= */
page {
  background-color: #f7f8fa;
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
  height: 100vh;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  overflow: hidden;
}

.container {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
}

/* ================= 2. 顶部导航栏 (极致紧凑贴顶版) ================= */
.top-nav {
  position: relative;
  width: 100vw;
  
  /* 【旋钮1：控制文字距离屏幕物理顶部的间距】 */
  /* 设置为 0rpx 就是死死贴住物理屏幕最上边缘。建议保留 40rpx 避开刘海和电量图标 */
  padding-top: 0rpx; 
  
  /* 【旋钮2：控制整个导航栏的高度】 */
  /* 高度越小，下方的“全部、待确认”Tab 就越往上提。60rpx 已经非常紧凑了！ */
  height: 60rpx; 
  
  background-color: #f7f8fa;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  z-index: 999;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  letter-spacing: 2rpx;
  max-width: 45%;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 返回按钮：绝对定位，动态垂直居中对齐 */
.nav-back {
  position: absolute;
  left: 10rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: opacity 0.2s;
}

/* 扫码按钮：绝对定位，动态垂直居中对齐 */
.nav-scan {
  position: absolute;
  left: 98rpx;
  top: 50%; 
  transform: translateY(-50%);
  width: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: opacity 0.2s;
}

.nav-back-hover, .nav-scan-hover {
  opacity: 0.5;
}

.back-icon, .scan-icon {
  width: 40rpx;
  height: 40rpx;
}

text.back-icon {
  font-size: 44rpx;
  font-family: Arial, Helvetica, sans-serif;
  font-weight: 300;
  color: #333;
}

/* ================= 3. 顶部横向筛选栏 ================= */
.order-filter {
  display: flex;
  flex-wrap: nowrap;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
  background: #fff;
  padding: 0 10rpx;
  border-bottom: 1rpx solid #eee;
  flex-shrink: 0;
}
.order-filter::-webkit-scrollbar {
  display: none;
}
.filter-item {
  display: inline-block;
  padding: 24rpx 30rpx;
  font-size: 28rpx;
  color: #666;
  flex-shrink: 0;
  position: relative;
  transition: all 0.2s;
}
.filter-item.active {
  color: #1890FF; 
  font-weight: bold;
}
.filter-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 6rpx;
  background: #1890FF;
  border-radius: 4rpx;
}

/* ================= 4. 滚动列表区 ================= */
.list-scroll-container {
  flex: 1; 
  height: 0;
  width: 100%;
  box-sizing: border-box;
}

.order-section {
  padding: 24rpx;
  box-sizing: border-box;
}

/* 空数据提示 */
.empty-record {
  text-align: center;
  font-size: 28rpx;
  color: #999;
  padding: 100rpx 0;
}

/* ================= 5. 订单卡片与内容 ================= */
.order-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.02);
}

.order-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  border-bottom: 1rpx dashed #eee;
  padding-bottom: 20rpx;
}
.order-id {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
}

/* 状态标签 */
.order-status {
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 500;
  background-color: #f5f5f5; /* 默认保底色 */
  color: #666;
}
.status-pending_confirm { color: #FAAD14; background: rgba(250, 173, 20, 0.1); }
.status-pending_material { color: #722ED1; background: rgba(114, 46, 209, 0.1); }
.status-producing { color: #1890FF; background: rgba(24, 144, 255, 0.1); }
.status-pending_ship { color: #D48806; background: rgba(255, 251, 230, 1); border: 1rpx solid #FFE58F; }
.status-shipped { color: #13C2C2; background: rgba(19, 194, 194, 0.1); }
.status-completed { color: #52C41A; background: rgba(82, 196, 26, 0.1); }

/* 基础信息组 */
.info-group {
  margin-bottom: 24rpx;
}
.info-line {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
  font-size: 26rpx;
}
.info-line:last-child {
  margin-bottom: 0;
}
.info-label {
  color: #888;
  flex-shrink: 0;
}
.info-value {
  color: #333;
  font-weight: 500;
  flex: 1;
}
.ml-12 {
  margin-left: 24rpx;
}

/* ================= 6. 生产工序与状态轴 ================= */
.process-box {
  background: #fdfdfd;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 24rpx;
  border: 1px solid #f0f0f0;
}
.process-title {
  font-size: 26rpx;
  color: #666;
  display: block;
  margin-bottom: 16rpx;
  font-weight: 500;
}
.process-flow {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}
.process-item {
  padding: 8rpx 20rpx;
  background-color: #f5f5f5;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #999;
  transition: all 0.2s ease;
}
.process-item.done {
  background-color: #e6f7ff;
  color: #1890FF;
  border: 1px solid #91d5ff;
}

/* 底部状态横向时间轴 */
.status-flow {
  display: flex;
  align-items: center;
  margin-top: 24rpx;
  overflow-x: auto;
  padding: 10rpx 0;
  -webkit-overflow-scrolling: touch;
}
.status-flow::-webkit-scrollbar {
  display: none;
}
.node {
  font-size: 24rpx;
  color: #999;
  white-space: nowrap;
  flex-shrink: 0;
}
.node.active {
  color: #1890FF;
  font-weight: 600;
}
.node.done {
  color: #52C41A;
}
.line {
  width: 40rpx;
  height: 2rpx;
  background-color: #eee;
  margin: 0 16rpx;
  flex-shrink: 0;
}
.line.done {
  background-color: #52C41A;
}

/* ================= 7. 卡片操作按钮 ================= */
.order-action {
  display: flex;
  justify-content: flex-end;
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f9f9f9;
}
.update-btn {
  margin: 0 !important;
  background: linear-gradient(135deg, #1890FF, #40A9FF) !important;
  color: #fff !important;
  border-radius: 32rpx;
  font-size: 26rpx !important;
  font-weight: 500;
  padding: 10rpx 32rpx !important;
  line-height: 1.5;
}

/* ================= 8. 弹窗样式规范化 ================= */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background-color: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}
.modal-content {
  width: 600rpx;
  background-color: #fff;
  border-radius: 24rpx;
  padding: 40rpx 40rpx 30rpx;
  box-sizing: border-box;
}
.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  text-align: center;
  margin-bottom: 30rpx;
}
.info-row {
  display: flex;
  margin-bottom: 16rpx;
  font-size: 28rpx;
}
.picker-wrap {
  margin-top: 30rpx;
}
.picker-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
  display: block;
}
.picker, .scan-status-btn {
  padding: 20rpx 24rpx;
  border: 1rpx solid #e8e8e8;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  background-color: #fafafa;
  display: flex;
  align-items: center;
}
.scan-small-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 16rpx;
}
.modal-actions {
  display: flex;
  gap: 24rpx;
  margin-top: 40rpx;
}
.modal-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
  font-size: 30rpx;
  padding: 0;
  margin: 0 !important;
}
.cancel-btn {
  background-color: #f5f5f5;
  color: #666;
}
.confirm-btn {
  background: linear-gradient(135deg, #1890FF, #0050B3);
  color: #fff;
}

/* ================= 9. 底部悬浮新建按钮 ================= */
.fixed-bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  padding: 20rpx 30rpx calc(20rpx + env(safe-area-inset-bottom)); 
  background-color: #ffffff;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
  box-sizing: border-box;
}

.create-order-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #1890FF, #0050B3);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 16rpx rgba(24, 144, 255, 0.3);
}

.plus-icon {
  font-size: 40rpx;
  margin-right: 8rpx;
  font-weight: 300;
  line-height: 88rpx;
}

.safe-bottom-holder {
  height: 160rpx; 
  width: 100%;
  background: transparent;
}

/* ================= 10. 统一视觉覆盖：橙金工业卡片风 ================= */
page {
  background:
    radial-gradient(circle at 12% 0%, rgba(251, 171, 6, 0.16), transparent 34%),
    linear-gradient(180deg, #f8fafc 0%, #ffffff 100%);
}

.top-nav {
  background: rgba(248, 250, 252, 0.96);
  border-bottom: 1rpx solid rgba(226, 232, 240, 0.8);
}

.nav-title {
  color: #0f172a;
  font-weight: 800;
}

text.back-icon {
  color: #0f172a;
}

.order-filter {
  background: rgba(255, 255, 255, 0.95);
  border-bottom: 1rpx solid rgba(226, 232, 240, 0.85);
}

.filter-item {
  color: #64748b;
}

.filter-item.active {
  color: #d48806;
}

.filter-item.active::after {
  background: linear-gradient(90deg, #fbab06, #ffd666);
}

.order-card,
.modal-content {
  border-radius: 32rpx;
  border: 1rpx solid rgba(226, 232, 240, 0.86);
  box-shadow: 0 18rpx 44rpx rgba(15, 23, 42, 0.07);
}

.order-card {
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(255, 250, 242, 0.95));
}

.order-id,
.info-value,
.modal-title {
  color: #0f172a;
}

.info-label,
.process-title,
.node {
  color: #64748b;
}

.order-head {
  border-bottom-color: rgba(226, 232, 240, 0.9);
}

.status-producing,
.node.active {
  color: #d48806;
  background: rgba(251, 171, 6, 0.12);
}

.process-box {
  background: #fffaf2;
  border-color: rgba(251, 171, 6, 0.18);
  border-radius: 24rpx;
}

.process-item.done {
  background: #fff7e8;
  color: #d48806;
  border-color: rgba(251, 171, 6, 0.45);
}

.line.done {
  background: linear-gradient(90deg, #fbab06, #52c41a);
}

.update-btn,
.confirm-btn,
.create-order-btn {
  background: linear-gradient(135deg, #fbab06, #d48806) !important;
  box-shadow: 0 12rpx 26rpx rgba(251, 171, 6, 0.28);
}

.fixed-bottom-bar {
  background: rgba(255, 255, 255, 0.96);
  border-top: 1rpx solid rgba(226, 232, 240, 0.85);
  box-shadow: 0 -16rpx 44rpx rgba(15, 23, 42, 0.06);
}
