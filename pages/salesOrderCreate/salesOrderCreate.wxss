page {
  background-color: #f7f8fa;
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
  box-sizing: border-box;
  height: 100vh;
  /* 强制清空可能存在的全局 padding 和 margin，绝不留灰边 */
  padding-top: 0 !important; 
  margin: 0 !important;
  overflow: hidden;
}

.container {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  padding: 0 !important; 
  margin: 0 !important;
}

/* 顶部导航 - 完美适配刘海屏 */
.top-nav {
  width: 100%;
  box-sizing: content-box;
  padding-top: max(env(safe-area-inset-top), 20px); 
  height: 88rpx; 
  background-color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  flex-shrink: 0;
  z-index: 100;
}

.nav-back {
  position: absolute;
  left: 20rpx;
  bottom: 0;
  height: 88rpx;
  width: 80rpx;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  padding-left: 10rpx;
}

.back-icon { 
  font-size: 40rpx;
  color: #333;
}

.nav-title { 
  font-size: 34rpx; 
  font-weight: 600; 
  color: #333; 
}

/* 滚动区域 */
.form-scroll-container {
  flex: 1;
  width: 100%;
  box-sizing: border-box;
}

/* 卡片样式 */
.form-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 0 30rpx 10rpx;
  margin: 20rpx 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.02);
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  padding: 30rpx 0 20rpx;
  border-bottom: 1rpx solid #f5f5f5;
  margin-bottom: 10rpx;
}

/* ================= 商品明细增强布局 ================= */
.item-box {
  background: #fdfdfd;
  border-radius: 16rpx;
  padding: 0 24rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid #f0f0f0;
  position: relative;
}

.item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0 16rpx;
  border-bottom: 1rpx dashed #eee;
}

.item-title {
  font-size: 26rpx;
  color: #888;
  font-weight: 500;
}

/* 支持一行放两个输入框 (可选使用) */
.form-row {
  display: flex;
  gap: 20rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.form-row .form-item {
  flex: 1;
  border-bottom: none;
}

/* 表单项通用样式 */
.form-item {
  display: flex;
  align-items: center;
  min-height: 100rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.form-item:last-child {
  border-bottom: none;
}

.form-label {
  min-width: 180rpx;
  font-size: 28rpx;
  color: #333;
  flex-shrink: 0;
}

.required {
  color: #F5222D;
  margin-right: 4rpx;
}

/* 输入控件对齐 */
.form-input, .picker-view {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  text-align: right; 
  height: 80rpx;
  line-height: 80rpx;
}

.placeholder {
  color: #ccc;
}

/* 只读文本展示（如总数量） */
.readonly-text {
  color: #1890FF !important;
  font-weight: 600;
  font-family: Arial, Helvetica, sans-serif;
}

/* 开关组件 */
switch {
  margin-left: auto;
  transform: scale(0.85);
  transform-origin: right center;
}

/* 按钮区域 */
.fixed-bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  padding: 24rpx 30rpx calc(24rpx + env(safe-area-inset-bottom));
  background-color: #ffffff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
  display: flex;
  gap: 24rpx;
  z-index: 100;
  box-sizing: border-box;
}

.btn {
  flex: 1;
  height: 92rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  font-size: 30rpx;
  font-weight: 500;
  border-radius: 46rpx;
}

.btn-cancel {
  background-color: #f5f5f5;
  color: #666;
}

.btn-submit {
  background: linear-gradient(135deg, #1890FF, #0050B3);
  color: #ffffff;
  box-shadow: 0 6rpx 12rpx rgba(24, 144, 255, 0.3);
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.add-btn {
  font-size: 24rpx;
  color: #1890FF;
  border: 1rpx solid #1890FF;
  padding: 6rpx 20rpx;
  border-radius: 30rpx;
}

.delete-btn {
  font-size: 24rpx;
  color: #ff4d4f;
  font-weight: normal;
}

.safe-bottom-area {
  height: 220rpx; /* 留出足够空间不被底部栏遮挡 */
}

/* ================= 统一视觉覆盖：新建销售订单 ================= */
page {
  background:
    radial-gradient(circle at 12% 0%, rgba(31, 111, 255, 0.16), transparent 34%),
    linear-gradient(180deg, #f8fafc 0%, #ffffff 100%);
}

.top-nav,
.fixed-bottom-bar {
  background: rgba(255, 255, 255, 0.96);
  border-bottom: 1rpx solid rgba(226, 232, 240, 0.86);
}

.fixed-bottom-bar {
  border-top: 1rpx solid rgba(226, 232, 240, 0.86);
  border-bottom: none;
  box-shadow: 0 -16rpx 44rpx rgba(15, 23, 42, 0.06);
}

.nav-title,
.card-title,
.form-label {
  color: #071f5f;
}

.form-card,
.item-box {
  border-radius: 32rpx;
  border: 1rpx solid rgba(226, 232, 240, 0.86);
  box-shadow: 0 18rpx 44rpx rgba(15, 23, 42, 0.07);
}

.form-card {
  background: rgba(255, 255, 255, 0.96);
}

.item-box {
  background: #f3f8ff;
  border-color: rgba(31, 111, 255, 0.18);
}

.card-title {
  position: relative;
  padding-left: 18rpx;
}

.card-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  width: 6rpx;
  height: 24rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #1f6fff, #8fd0ff);
  transform: translateY(-50%);
}

.readonly-text,
.add-btn {
  color: #0b2a6f !important;
}

.add-btn {
  border-color: #1f6fff;
  background: #eef6ff;
}

.btn-submit {
  background: linear-gradient(135deg, #1f6fff, #0b2a6f);
  box-shadow: 0 12rpx 26rpx rgba(31, 111, 255, 0.28);
}

.btn-cancel {
  background: #eef2f7;
  color: #475569;
}
