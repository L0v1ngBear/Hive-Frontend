page {
  background-color: #f7f8fa;
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
  padding-top: env(safe-area-inset-top);
  box-sizing: border-box;
  height: 100vh;
  overflow: hidden;
}

.container {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
}

/* 顶部导航 */
.top-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx 40rpx 20rpx 20rpx;
  background-color: #fff;
  flex-shrink: 0;
  z-index: 10;
}
.nav-back, .nav-scan {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.back-icon { width: 36rpx; height: 36rpx; }
.nav-title { font-size: 34rpx; font-weight: 600; color: #333; }

/* 滚动区域 */
.form-scroll-container {
  flex: 1;
  width: 100%;
  padding: 20rpx 24rpx;
  box-sizing: border-box;
}

/* 卡片样式 */
.form-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 0 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.02);
}
.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  padding: 30rpx 0 10rpx;
  border-bottom: 1rpx solid #f5f5f5;
  margin-bottom: 10rpx;
}

/* 表单项 */
.form-item {
  display: flex;
  align-items: center;
  min-height: 100rpx;
  border-bottom: 1rpx solid #f5f5f5;
  position: relative;
}
.form-item:last-child {
  border-bottom: none;
}
.form-item.align-top {
  align-items: flex-start;
  padding-top: 30rpx;
  padding-bottom: 30rpx;
}

.form-label {
  width: 180rpx;
  font-size: 28rpx;
  color: #333;
  flex-shrink: 0;
}
.required {
  color: #F5222D;
  margin-right: 4rpx;
}

.form-input, .picker-view {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  text-align: right; /* 输入内容靠右对齐 */
}
.form-textarea {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  min-height: 120rpx;
  text-align: right;
}
.placeholder {
  color: #ccc;
}
.arrow-right {
  color: #ccc;
  margin-left: 10rpx;
  font-family: "Courier New", Courier, monospace;
}

/* 底部操作栏 */
.safe-bottom-area {
  height: 160rpx;
}
.fixed-bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  padding: 20rpx 30rpx calc(20rpx + env(safe-area-inset-bottom));
  background-color: #ffffff;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.05);
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  z-index: 100;
  box-sizing: border-box;
}

.btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 44rpx;
  margin: 0 !important;
}
.btn::after { border: none; }
.btn-cancel {
  background-color: #f5f5f5;
  color: #666;
}
.btn-submit {
  background: linear-gradient(135deg, #1890FF, #40A9FF);
  color: #ffffff;
}