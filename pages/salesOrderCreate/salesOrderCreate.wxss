page {
  background-color: #f7f8fa;
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
  box-sizing: border-box;
  height: 100vh;
  overflow: hidden;
  /* 强制清空可能存在的全局 padding 和 margin，绝不留灰边 */
  padding-top: 0 !important; 
  margin: 0 !important;
}

.container {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  /* 确保容器自身没有任何缩进 */
  padding: 0 !important; 
  margin: 0 !important;
}

/* 顶部导航 - 完美适配刘海屏与状态栏，消除多余空白 */
.top-nav {
  width: 100%;
  box-sizing: content-box;
  /* 用白色的 padding 去吸收状态栏高度，保证白色背景直达屏幕最顶端 */
  padding-top: max(env(safe-area-inset-top), 20px); 
  height: 88rpx; /* 严格等于微信右侧胶囊的标准高度 */
  background-color: #fff;
  display: flex;
  align-items: center;
  justify-content: center; /* 确保标题绝对居中 */
  position: relative;
  flex-shrink: 0;
  z-index: 100;
}

.nav-back {
  position: absolute;
  left: 20rpx;
  bottom: 0;
  height: 88rpx;
  width: 80rpx;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  padding-left: 10rpx;
}

.back-icon { 
  width: 36rpx; 
  height: 36rpx; 
}

.nav-title { 
  font-size: 34rpx; 
  font-weight: 600; 
  color: #333; 
}

.nav-scan {
  display: none; /* 采用绝对定位后，右侧占位不需要了 */
}

/* 滚动区域 */
.form-scroll-container {
  flex: 1;
  width: 100%;
  padding: 20rpx 24rpx;
  box-sizing: border-box;
}

/* 卡片样式 */
.form-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 0 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.02);
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  padding: 30rpx 0 10rpx;
  border-bottom: 1rpx solid #f5f5f5;
  margin-bottom: 10rpx;
}

/* 表单项 */
.form-item {
  display: flex;
  align-items: center;
  min-height: 100rpx;
  border-bottom: 1rpx solid #f5f5f5;
  position: relative;
}

.form-item:last-child {
  border-bottom: none;
}

.form-label {
  width: 260rpx; /* 加宽标签宽度，防止“同步创建生产订单”折行 */
  font-size: 28rpx;
  color: #333;
  flex-shrink: 0;
}

.required {
  color: #F5222D;
  margin-right: 4rpx;
}

/* 输入框与选择器对齐优化 */
picker {
  flex: 1; 
}

.form-input, .picker-view {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  text-align: right; 
}

/* 开关组件靠右对齐优化 */
.form-item switch {
  margin-left: auto; 
  transform: scale(0.9); 
  transform-origin: right center; 
}

.placeholder {
  color: #ccc;
}

.arrow-right {
  color: #ccc;
  margin-left: 10rpx;
  font-family: "Courier New", Courier, monospace;
}

/* 底部操作栏 */
.safe-bottom-area {
  height: 180rpx; 
}

.fixed-bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  padding: 20rpx 30rpx calc(20rpx + env(safe-area-inset-bottom));
  background-color: #ffffff;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.05);
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  z-index: 100;
  box-sizing: border-box;
}

/* 使用 flexbox 强行矫正微信 button 的文字居中问题 */
.btn {
  flex: 1;
  height: 88rpx;
  display: flex;          /* 启用 Flex 布局 */
  align-items: center;    /* 垂直居中 */
  justify-content: center;/* 水平居中 */
  padding: 0;             /* 清除默认内边距 */
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 44rpx;
  margin: 0 !important;
}

.btn::after { border: none; }

.btn-cancel {
  background-color: #f5f5f5;
  color: #666;
}

.btn-submit {
  background: linear-gradient(135deg, #1890FF, #40A9FF);
  color: #ffffff;
}