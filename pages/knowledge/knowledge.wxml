<view class="container">
  <view class="toolbar">
    <view class="btn-group">
      <view class="tool-btn" bindtap="openCreateModal">
        <image class="icon" src="/images/folder-add.png"></image>
        <text>新建文件夹</text>
      </view>
      <view class="tool-btn" bindtap="chooseAndUploadFile">
        <image class="icon" src="/images/upload.png"></image>
        <text>上传文件</text>
      </view>
    </view>
    
    <view class="view-toggle" bindtap="toggleViewMode">
      <text class="toggle-text">{{viewMode === 'grid' ? '列表视图' : '大图标'}}</text>
    </view>
  </view>

  <view class="breadcrumb">
    <scroll-view scroll-x class="breadcrumb-scroll">
      <block wx:for="{{breadcrumbs}}" wx:key="id">
        <text class="bread-text" bindtap="handleBreadcrumbClick" data-id="{{item.id}}">{{item.name}}</text>
        <text class="separator" wx:if="{{index < breadcrumbs.length - 1}}">></text>
      </block>
    </scroll-view>
  </view>

  <scroll-view class="file-content" scroll-y>
    
    <view class="file-grid" wx:if="{{viewMode === 'grid'}}">
      <view class="grid-item" 
            wx:for="{{documentList}}" 
            wx:key="id" 
            bindtap="handleItemClick" 
            bindlongpress="handleItemLongPress" 
            data-item="{{item}}">
        <image class="grid-icon" src="{{(item.type === 1 || item.type === 'folder') ? '/images/folder.png' : '/images/file.png'}}"></image>
        <text class="grid-name">{{item.name}}</text>
      </view>
    </view>

    <view class="file-list" wx:if="{{viewMode === 'list'}}">
      <view class="list-header" wx:if="{{documentList.length > 0}}">
        <text class="col-name">名称</text>
        <text class="col-date">修改日期</text>
      </view>
      
      <view class="file-item" wx:for="{{documentList}}" wx:key="id">
        <view class="item-main" bindtap="handleItemClick" data-item="{{item}}">
          <image class="type-icon-small" src="{{(item.type === 1 || item.type === 'folder') ? '/images/folder.png' : '/images/file.png'}}"></image>
          <text class="item-name">{{item.name}}</text>
        </view>
        <text class="item-date">{{item.updateTime || '--'}}</text>
        <view class="more-btn" catchtap="handleItemLongPress" data-item="{{item}}">
          <text class="dot">...</text>
        </view>
      </view>
    </view>
    
    <view class="empty-state" wx:if="{{documentList.length === 0}}">
      <text>此文件夹为空</text>
    </view>
  </scroll-view>
</view>