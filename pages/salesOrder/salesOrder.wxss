/* 直接引入生产订单的基础结构样式 */
@import "../order/order.wxss";

/* ================= 1. 基础特有样式 ================= */
.font-bold {
  font-weight: 600;
  color: #1a1a1a;
}
.price-text {
  color: #E02020;
  font-weight: 600;
  font-size: 30rpx;
}

/* ================= 2. 顶部横向筛选栏 ================= */
.order-filter-scroll {
  width: 100%;
  white-space: nowrap;
  background: #fff;
  border-bottom: 1rpx solid #eee;
  position: sticky;
  top: 0;
  z-index: 99;
}

.order-filter {
  display: flex;
  padding: 0 10rpx;
}

.filter-item {
  display: inline-block;
  padding: 24rpx 30rpx;
  font-size: 28rpx;
  color: #666;
  flex-shrink: 0;
  position: relative;
  transition: all 0.2s;
}

.filter-item.active {
  color: #1890FF; 
  font-weight: bold;
}
.filter-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 6rpx;
  background: #1890FF;
  border-radius: 4rpx;
}

/* ================= 3. 状态标签样式 (优化背景色) ================= */
.order-status {
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 500;
}
/* 待确认：橙色 */
.status-pending_confirm { color: #FAAD14; background: rgba(250, 173, 20, 0.1); }
/* 备料中：紫色 */
.status-pending_material { color: #722ED1; background: rgba(114, 46, 209, 0.1); }
/* 生产中：明蓝色 */
.status-producing { color: #1890FF; background: rgba(24, 144, 255, 0.1); }
/* 待发货：金黄色 */
.status-pending_ship { color: #D48806; background: rgba(255, 251, 230, 1); border: 1rpx solid #FFE58F; }
/* 已发货：青色 */
.status-shipped { color: #13C2C2; background: rgba(19, 194, 194, 0.1); }
/* 已完成：绿色 */
.status-completed { color: #52C41A; background: rgba(82, 196, 26, 0.1); }

/* ================= 4. 按钮组样式 ================= */
.order-action {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  margin-top: 20rpx;
}
.action-btn {
  margin: 0 !important;
  border-radius: 32rpx;
  font-size: 26rpx;
  font-weight: 500;
  padding: 8rpx 24rpx;
  line-height: 1.5;
}
.btn-primary {
  background: linear-gradient(135deg, #1890FF, #40A9FF);
  color: #fff;
  border: none;
}
.btn-default {
  background: #fff;
  color: #666;
  border: 1rpx solid #ddd;
}

/* ================= 5. 底部悬浮新建按钮 ================= */
.fixed-bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  padding: 20rpx 30rpx calc(20rpx + env(safe-area-inset-bottom)); 
  background-color: #ffffff;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
  box-sizing: border-box;
}

.create-order-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #1890FF, #0050B3);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 16rpx rgba(24, 144, 255, 0.3);
}

/* ================= 6. 商品明细适配 (适配 weight & spec) ================= */
.align-top {
  align-items: flex-start !important;
}

.goods-box {
  background-color: #f7f8fa;
  border-radius: 12rpx;
  padding: 16rpx;
  flex: 1;
}

.goods-item {
  display: flex;
  flex-direction: column; /* 改为纵向布局以容纳更多参数 */
  padding-bottom: 12rpx;
  margin-bottom: 12rpx;
  border-bottom: 1rpx solid #eee;
}

.goods-item:last-child {
  margin-bottom: 0;
  padding-bottom: 0;
  border-bottom: none;
}

.g-main {
  display: flex;
  justify-content: space-between;
  align-items: center;
  width: 100%;
}

.g-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.g-qty {
  color: #1890FF;
  font-weight: bold;
  font-size: 26rpx;
}

/* 新增参数标签组样式 */
.g-params {
  display: flex;
  gap: 12rpx;
  margin-top: 8rpx;
}

.param-tag {
  font-size: 22rpx;
  color: #666;
  background: #fff;
  border: 1rpx solid #e0e0e0;
  padding: 2rpx 12rpx;
  border-radius: 4rpx;
}

/* 同步生产标签 */
.sync-tag {
  font-size: 20rpx;
  color: #722ED1;
  background: #F9F0FF;
  border: 1rpx solid #D3ADF7;
  padding: 2rpx 8rpx;
  border-radius: 4rpx;
}

/* 辅助样式 */
.mt-8 { margin-top: 8rpx; }
.ml-12 { margin-left: 24rpx; }
.text-grey { color: #888; font-size: 24rpx; }