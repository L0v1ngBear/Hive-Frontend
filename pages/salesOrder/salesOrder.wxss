/* 直接引入生产订单的基础结构样式，保证UI统一 */
@import "../order/order.wxss";

/* ================= 1. 基础特有样式 ================= */
.font-bold {
  font-weight: 600;
  color: #1a1a1a;
}
.price-text {
  color: #E02020;
  font-weight: 600;
  font-size: 15px;
}

/* ================= 2. 顶部横向筛选栏 ================= */
.order-filter-scroll {
  width: 100%;
  white-space: nowrap; /* 保证子元素不换行，实现横向滚动 */
  background: #fff;
  border-bottom: 1rpx solid #eee;
}

.order-filter {
  display: flex;
  padding: 0 10rpx;
}

.filter-item {
  display: inline-block;
  padding: 24rpx 30rpx;
  font-size: 28rpx;
  color: #666;
  flex-shrink: 0;
  position: relative;
  transition: all 0.2s;
}

/* 选中状态：文字变色 + 底部小蓝条 */
.filter-item.active {
  color: #1890FF; 
  font-weight: bold;
}
.filter-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 6rpx;
  background: #1890FF;
  border-radius: 4rpx;
}

/* ================= 3. 状态颜色重写 (匹配最新枚举) ================= */
/* 待确认：橙色 */
.status-pending_confirm { color: #FAAD14; background-color: rgba(250, 173, 20, 0.1); }
/* 备料中：紫色 */
.status-pending_material { color: #722ED1; background-color: rgba(114, 46, 209, 0.1); }
/* 生产中：明蓝色 */
.status-producing { color: #1890FF; background-color: rgba(24, 144, 255, 0.1); }
/* 待发货：红橙色 */
.status-pending_ship { color: #F5A623; background-color: rgba(245, 166, 35, 0.1); }
/* 已发货：青色 */
.status-shipped { color: #13C2C2; background-color: rgba(19, 194, 194, 0.1); }
/* 已完成：绿色 */
.status-completed { color: #52C41A; background-color: rgba(82, 196, 26, 0.1); }
/* 取消/其他：灰色 */
.status-cancelled { color: #999; background-color: #f5f5f5; }

/* ================= 4. 按钮组样式 ================= */
.order-action {
  gap: 10px;
}
.action-btn {
  margin: 0 !important;
  border-radius: 16px;
  font-size: 13px;
  font-weight: 500;
  padding: 4px 16px;
}
.btn-primary {
  background: linear-gradient(135deg, #1890FF, #40A9FF);
  color: #fff;
}
.btn-default {
  background: #fff;
  color: #666;
  border: 1px solid #ddd;
}

/* ================= 5. 底部悬浮新建按钮 ================= */
.fixed-bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  /* padding-bottom 适配全面屏底部安全区（如 iPhone 小黑条） */
  padding: 20rpx 30rpx calc(20rpx + env(safe-area-inset-bottom)); 
  background-color: #ffffff;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
  box-sizing: border-box;
}

.create-order-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #1890FF, #40A9FF); /* 保持主按钮颜色一致 */
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.create-order-btn::after {
  border: none;
}

.plus-icon {
  font-size: 40rpx;
  margin-right: 12rpx;
  font-weight: 400;
  margin-top: -4rpx;
}

/* ================= 6. 滚动条美化 ================= */
.show-scrollbar::-webkit-scrollbar {
  display: block !important;
  width: 4px !important;
  background-color: transparent;
}
.show-scrollbar::-webkit-scrollbar-thumb {
  border-radius: 4px;
  background-color: rgba(0, 0, 0, 0.2);
}