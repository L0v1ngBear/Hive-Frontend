<view class="container">
  <view class="top-nav">
    <view class="nav-back" bindtap="handleBack">
      <text class="back-icon">＜</text>
    </view>
    <text class="nav-title">销售订单管理</text>
    <view class="nav-scan" bindtap="handleSearch">
      <icon type="search" size="18" color="#333"></icon>
    </view>
  </view>

  <scroll-view class="order-filter-scroll" scroll-x="true" enable-flex="true">
    <view class="order-filter">
      <view class="filter-item {{currentFilter==item.key?'active':''}}" wx:for="{{filterList}}" wx:key="key"
        bindtap="handleFilter" data-filter="{{item.key}}">
        {{item.label}}
      </view>
    </view>
  </scroll-view>

  <scroll-view class="list-scroll-container" scroll-y="true" enhanced="true" bounces="true">
    <view class="order-section">
      <view wx:if="{{filteredOrderList.length === 0}}" class="empty-record">
        <text>暂无相关订单</text>
      </view>

      <block wx:for="{{filteredOrderList}}" wx:key="orderId">
        <view class="order-card">
          <view class="order-head" bindtap="openDetail" data-order="{{item}}">
            <text class="order-id">单号：{{item.orderId}}</text>
            <text class="order-status status-{{item.status}}">{{statusMap[item.status]}}</text>
          </view>

          <view class="info-group" bindtap="openDetail" data-order="{{item}}">
            <view class="info-line">
              <text class="info-label">客户：</text>
              <text class="info-value font-bold">{{item.customerName}}</text>
            </view>
            
            <view class="info-line">
              <text class="info-label">项目：</text>
              <text class="info-value">{{item.projectName || '默认项目'}}</text>
            </view>

            <view class="info-line align-top">
              <text class="info-label">明细：</text>
              <view class="info-value goods-box">
                <view class="goods-item" wx:for="{{item.items}}" wx:key="index" wx:for-item="goods">
                  <view class="g-main">
                    <text class="g-name">{{goods.modelCode}}</text>
                    <text class="g-qty">x {{goods.quantity}}米</text>
                  </view>
                  <view class="g-tags">
                    <text class="g-tag">{{goods.weight}}g/㎡</text>
                    <text class="g-tag">{{goods.spec}}cm</text>
                  </view>
                </view>
              </view>
            </view>

            <view class="info-line mt-8">
              <text class="info-label">交期：</text>
              <text class="info-value">{{item.deliveryDate}}</text>
              <text class="info-label ml-12" wx:if="{{item.createProductionOrder === 1}}">
                <text class="sync-tag">同步生产</text>
              </text>
            </view>
          </view>

          <view class="order-action">
            <button wx:if="{{item.status === 'pending_confirm'}}" class="action-btn btn-primary" size="mini"
              catchtap="handleAction" data-type="confirm" data-order="{{item}}">确认订单</button>
            <button wx:if="{{item.status === 'pending_ship'}}" class="action-btn btn-primary" size="mini"
              catchtap="handleAction" data-type="ship" data-order="{{item}}">录入发货</button>
            <button wx:if="{{item.status === 'shipped'}}" class="action-btn btn-primary" size="mini"
              catchtap="handleAction" data-type="finish" data-order="{{item}}">完成订单</button>
          </view>
        </view>
      </block>
      <view class="safe-bottom-holder"></view>
    </view>
  </scroll-view>

  <view class="fixed-bottom-bar">
    <button class="create-order-btn" bindtap="handleCreateOrder">
      <text class="plus-icon">+</text> 新建销售订单
    </button>
  </view>
</view>