page { 
  background-color: #f5f5f5; 
  height: 100vh; 
  display: flex; 
  flex-direction: column; 
}
.container { 
  padding: 30rpx; 
  display: flex; 
  flex-direction: column; 
  height: 100%; 
  box-sizing: border-box;
}
.header { 
  display: flex; 
  justify-content: space-between; 
  align-items: center; 
  margin-bottom: 30rpx; 
}
.title { 
  font-size: 34rpx; 
  font-weight: bold; 
  color: #333;
}
.scan-btn { 
  margin: 0; 
  font-size: 28rpx; 
  width: 220rpx; 
  border-radius: 40rpx; 
}
.device-list { 
  flex: 1; 
  background: #fff; 
  border-radius: 20rpx; 
  padding: 10rpx 0; 
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}
.device-item { 
  display: flex; 
  justify-content: space-between; 
  align-items: center; 
  padding: 30rpx; 
  border-bottom: 1px solid #f0f0f0; 
  transition: all 0.2s;
}
.device-item:active { 
  background-color: #fafafa; 
}
.device-name { 
  font-size: 32rpx; 
  color: #333; 
  font-weight: 500; 
  display: block; 
}
.device-id { 
  font-size: 24rpx; 
  color: #999; 
  margin-top: 10rpx; 
  display: block; 
}
.connect-status { 
  color: #52C41A; 
  font-size: 28rpx; 
  font-weight: bold;
}
.empty { 
  text-align: center; 
  color: #999; 
  font-size: 28rpx; 
  padding-top: 100rpx; 
}