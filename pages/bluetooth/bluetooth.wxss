page { 
  background-color: #f5f5f5; 
  height: 100vh; 
  display: flex; 
  flex-direction: column; 
}
.container { 
  padding: 30rpx; 
  display: flex; 
  flex-direction: column; 
  height: 100%; 
  box-sizing: border-box;
}
.header { 
  display: flex; 
  justify-content: space-between; 
  align-items: center; 
  margin-bottom: 30rpx; 
}
.title { 
  font-size: 34rpx; 
  font-weight: bold; 
  color: #333;
}
.scan-btn { 
  margin: 0; 
  font-size: 28rpx; 
  width: 220rpx; 
  border-radius: 40rpx; 
}
.device-list { 
  flex: 1; 
  background: #fff; 
  border-radius: 20rpx; 
  padding: 10rpx 0; 
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}
.device-item { 
  display: flex; 
  justify-content: space-between; 
  align-items: center; 
  padding: 30rpx; 
  border-bottom: 1px solid #f0f0f0; 
  transition: all 0.2s;
}
.device-item:active { 
  background-color: #fafafa; 
}
.device-name { 
  font-size: 32rpx; 
  color: #333; 
  font-weight: 500; 
  display: block; 
}
.device-id { 
  font-size: 24rpx; 
  color: #999; 
  margin-top: 10rpx; 
  display: block; 
}
.connect-status { 
  color: #1f6fff; 
  font-size: 28rpx; 
  font-weight: bold;
}
.empty { 
  text-align: center; 
  color: #999; 
  font-size: 28rpx; 
  padding-top: 100rpx; 
}

/* 统一视觉覆盖：蓝牙页使用同一套卡片和云枢蓝按钮 */
page {
  background:
    radial-gradient(circle at 12% 0%, rgba(31, 111, 255, 0.16), transparent 34%),
    linear-gradient(180deg, #f8fafc 0%, #ffffff 100%);
}

.title,
.device-name {
  color: #071f5f;
}

.scan-btn {
  background: linear-gradient(135deg, #1f6fff, #0b2a6f);
  color: #ffffff;
  box-shadow: 0 12rpx 26rpx rgba(31, 111, 255, 0.28);
}

.scan-btn::after {
  border: none;
}

.device-list {
  border-radius: 32rpx;
  border: 1rpx solid rgba(226, 232, 240, 0.86);
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 18rpx 44rpx rgba(15, 23, 42, 0.07);
}

.device-id,
.empty {
  color: #64748b;
}

.device-item {
  border-bottom-color: #f1f5f9;
}
